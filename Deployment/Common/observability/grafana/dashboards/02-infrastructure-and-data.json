      "id": 1,
      "title": "Local Node Metrics Note",
      "type": "text",
      "options": {
        "code": {
          "language": "plaintext",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "Local Docker intentionally has limited node-exporter coverage in V1. Local PostgreSQL and Redis exporter panels should still show data. LocalCluster and Cloud show the full four-node fleet.",
        "mode": "markdown"
      }
    },
    {
      "description": "",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 3
      },
      "id": 2,
      "title": "Node Target Health",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "up{deployment_target=~\"$deployment_target\", job=~\"node-exporter|postgres-exporter|redis-exporter\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "description": "",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 3
      },
      "id": 3,
      "title": "CPU Usage By Node",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "100 * (1 - avg by (node) (rate(node_cpu_seconds_total{deployment_target=~\"$deployment_target\", mode=\"idle\"}[5m])))",
          "refId": "A",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
