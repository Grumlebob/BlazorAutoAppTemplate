# Copy this file to Deployment/.deploy.local.env and fill your local operator values.
# Deployment/.deploy.local.env is ignored by git.

LINUX_MINT_INSTALL_USER=jacob

# Optional: only needed if you use Deployment/scripts/setup-cloudflare-tunnel.sh.
# The normal HowToDeploy.md path uses the Cloudflare dashboard instead.
# CLOUDFLARE_ACCOUNT_ID=0123456789abcdef0123456789abcdef
# CLOUDFLARE_ZONE_ID=abcdef0123456789abcdef0123456789
# CLOUDFLARE_API_TOKEN=REPLACE_WITH_CLOUDFLARE_API_TOKEN
