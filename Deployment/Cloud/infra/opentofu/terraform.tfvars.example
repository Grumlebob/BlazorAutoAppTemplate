project_name = "bookscloud"
location = "fsn1"
network_zone = "eu-central"
server_type = "cx23"
image = "ubuntu-24.04"
ssh_public_key_path = "~/.ssh/bookscloud_deploy.pub"
public_ipv4_enabled = true
public_ipv6_enabled = true
admin_ssh_cidrs = ["REPLACE_WITH_YOUR_CURRENT_PUBLIC_IPV4/32"]
