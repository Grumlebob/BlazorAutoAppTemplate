<div class="bg-contain bg-no-repeat before:block before:pt-43 relative w-100" style="background-image: url(@ImagePath)">
    <div class="absolute inset-0 grid grid-cols-@Columns grid-rows-[@GridRowsToString()]">
        @for (var i = 0; i < Segments.Count; i++)
        {
            var localIndex = i;
            var cell = Segments[localIndex];
            cell.Layout ??= SetLayoutBasedOnIndexAndNumberOfSegments(localIndex);
            <div
                class="@StyleSegment(localIndex, cell)"
                @onclick="@(() => ToggleAsync(localIndex))">
                @if (!string.IsNullOrWhiteSpace(cell.Label))
                {
                    <p class="text-sm font-semibold leading-tight select-none"
                       style="color:#ffffff; text-shadow:-1px -1px 0 #111111, 1px -1px 0 #111111, -1px 1px 0 #111111, 1px 1px 0 #111111;">
                        @cell.Label
                    </p>
                }
            </div>
        }
    </div>
</div>

@code {
    public class Segment
    {
        public string Label { get; init; } = "";
        public bool IsInteractive { get; init; } = true;
        public bool IsPartial { get; set; }
        public bool IsCompleted { get; set; }
        public bool IsNotNeeded { get; set; }
        public string? Layout { get; set; } // Tailwind grid placement per cell
    }

    [Parameter] public int Columns { get; set; } = 4;
    [Parameter] public required string ImagePath { get; set; }

    /**
     * Set how much space each row should take up. E.g. [65, 35]
     * translates to: First row height: 65% second row height 35%
     */
    [Parameter]
    public required int[] GridRows { get; set; } = [100];

    [Parameter] public List<Segment> Segments { get; set; } = [new() { Label = "Segment" }];
    [Parameter] public int ActiveIndex { get; set; }
    [Parameter] public EventCallback<int> OnActiveIndexChanged { get; set; }
    [Parameter] public IReadOnlySet<int> PartialIndices { get; set; } = new HashSet<int>();
    [Parameter] public IReadOnlySet<int> CompletedIndices { get; set; } = new HashSet<int>();
    [Parameter] public IReadOnlySet<int> NotNeededIndices { get; set; } = new HashSet<int>();

    private int _currentlyToggled = -1;
    private string GridRowsToString() => string.Join('_', GridRows.Select(n => n + "%")); // [65, 35] => 65%_35%

    protected override void OnParametersSet()
    {
        if (Segments.Count == 0)
        {
            _currentlyToggled = -1;
            return;
        }

        _currentlyToggled = ActiveIndex >= 0 && ActiveIndex < Segments.Count
            ? ActiveIndex
            : -1;
        for (var i = 0; i < Segments.Count; i++)
        {
            Segments[i].IsPartial = PartialIndices.Contains(i);
            Segments[i].IsCompleted = CompletedIndices.Contains(i);
            Segments[i].IsNotNeeded = NotNeededIndices.Contains(i);
        }
    }

    private async Task ToggleAsync(int index)
    {
        if (index < 0 || index >= Segments.Count)
        {
            return;
        }

        if (!Segments[index].IsInteractive)
        {
            return;
        }

        _currentlyToggled = index;
        if (OnActiveIndexChanged.HasDelegate)
        {
            await OnActiveIndexChanged.InvokeAsync(index);
        }
    }

    private string SetLayoutBasedOnIndexAndNumberOfSegments(int index)
    {
        var colStart = 1;
        var colSpan = 1;
        var rowStart = 1;
        var rowSpan = 1;

        // first cell is stretched if *Columns* don't add up to number of segments
        var firstCellWidth = Columns - (Segments.Count - 1) % Columns;
        if (index == 0)
        {
            colSpan = firstCellWidth;
        }
        else
        {
            colStart = (index + firstCellWidth - 1) % Columns + 1;
            rowStart = (index + firstCellWidth - 1) / Columns + 1;
        }

        return $"col-start-{colStart} row-start-{rowStart} col-span-{colSpan} row-span-{rowSpan}";
    }

    private string StyleSegment(int index, Segment segment)
    {
        if (!segment.IsInteractive)
        {
            return $"{segment.Layout} flex items-start justify-start p-1 border-b border-slate-400 bg-transparent text-transparent pointer-events-none select-none";
        }

        var selection = _currentlyToggled == index ? "border-4 border-blue-700" : "border border-slate-300";
        var state = segment.IsNotNeeded
            ? "bg-blue-500/45 hover:bg-blue-500/35 text-white"
            : segment.IsCompleted
            ? "bg-green-700/50 hover:bg-green-700/35 text-white"
            : segment.IsPartial
                ? "bg-amber-400/55 hover:bg-amber-400/45 text-black"
                : "hover:bg-slate-100/60";
        return $"{segment.Layout} flex items-start justify-start p-1 cursor-pointer {selection} {state}";
    }
}
