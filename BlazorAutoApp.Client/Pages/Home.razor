@page "/"

<PageTitle>Home</PageTitle>

<div class="space-y-6">
    <div>
        <h1 class="text-3xl font-bold text-black">Welcome to the Blazor Auto sample</h1>
        <p class="text-black mb-4">Current rendering mode: @RendererInfo.Name</p>
    </div>

    <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
                <h2 class="text-xl font-semibold text-slate-900">IdentityShowcase</h2>
                <p class="text-sm text-slate-600">Live identity awareness with a secured API call.</p>
            </div>
            <button class="rounded bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-700 disabled:cursor-not-allowed disabled:bg-slate-400"
                    @onclick="RefreshIdentityShowcaseAsync"
                    disabled="@_identityLoading">
                Refresh
            </button>
        </div>

        @if (_identityLoading)
        {
            <div class="mt-4 rounded-md border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700">
                Loading identity diagnostics...
            </div>
        }
        else if (_identityError is not null)
        {
            <div class="mt-4 rounded-md border border-red-200 bg-red-50 p-3 text-sm text-red-700">
                @_identityError
            </div>
        }
        else
        {
            <div class="mt-4 rounded-md border border-blue-200 bg-blue-50 p-3 text-sm text-blue-900">
                <p class="font-medium">Public endpoint: @_publicInfo.Message</p>
                <p class="mt-1 text-xs text-blue-800">Server UTC: @_publicInfo.ServerTimeUtc.ToString("u")</p>
            </div>

            @if (_secureInfo is not null)
            {
                <div class="mt-4 rounded-md border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-900">
                    <h3 class="font-semibold">Authenticated view unlocked</h3>
                    <p class="mt-1">Secure endpoint call succeeded for <span class="font-medium">@_secureInfo.UserName</span>.</p>
                    <div class="mt-3 grid gap-2 text-xs text-emerald-800 md:grid-cols-2">
                        <div>User ID: @_secureInfo.UserId</div>
                        <div>Auth Type: @_secureInfo.AuthenticationType</div>
                        <div>Claims: @_secureInfo.ClaimCount</div>
                        <div>Server UTC: @_secureInfo.ServerTimeUtc.ToString("u")</div>
                    </div>
                    @if (_secureInfo.Roles.Length > 0)
                    {
                        <div class="mt-3 flex flex-wrap gap-2">
                            @foreach (var role in _secureInfo.Roles)
                            {
                                <span class="rounded-full bg-emerald-100 px-2 py-1 text-xs font-medium text-emerald-900">@role</span>
                            }
                        </div>
                    }
                    <div class="mt-3 flex flex-wrap gap-2 text-xs">
                        <span class="@(_secureInfo.IsViewer ? "rounded-full bg-sky-100 px-2 py-1 font-medium text-sky-900" : "rounded-full bg-slate-100 px-2 py-1 font-medium text-slate-700")">
                            Viewer: @(_secureInfo.IsViewer ? "Yes" : "No")
                        </span>
                        <span class="@(_secureInfo.IsAdmin ? "rounded-full bg-violet-100 px-2 py-1 font-medium text-violet-900" : "rounded-full bg-slate-100 px-2 py-1 font-medium text-slate-700")">
                            Admin: @(_secureInfo.IsAdmin ? "Yes" : "No")
                        </span>
                    </div>
                    <div class="mt-4 rounded-md border border-emerald-300 bg-emerald-100 p-3">
                        <div class="flex flex-wrap items-center gap-3">
                            <button class="rounded border border-emerald-500 px-3 py-2 text-sm font-medium text-emerald-900 hover:bg-emerald-200 disabled:cursor-not-allowed disabled:opacity-60"
                                    @onclick="RunAdminProbeAsync"
                                    disabled="@_adminProbeLoading">
                                @(_adminProbeLoading ? "Running Admin Probe..." : "Run Admin Probe")
                            </button>
                            <span class="text-xs text-emerald-900">Checks `Admin` role authorization through a protected endpoint.</span>
                        </div>
                        @if (_adminProbeResult is not null)
                        {
                            <div class="@($"mt-3 rounded p-2 text-xs {(_adminProbeResult.Success ? "bg-emerald-50 text-emerald-900" : "bg-amber-50 text-amber-900")}")">
                                @_adminProbeResult.Message
                                @if (_adminProbeResult.Roles.Length > 0)
                                {
                                    <div class="mt-1">Roles from probe: @string.Join(", ", _adminProbeResult.Roles)</div>
                                }
                            </div>
                        }
                    </div>
                    <button class="mt-4 rounded border border-emerald-400 px-3 py-2 text-sm font-medium text-emerald-900 hover:bg-emerald-100"
                            @onclick="GoToAccount">
                        Open Account
                    </button>
                </div>
            }
            else
            {
                <div class="mt-4 rounded-md border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
                    <h3 class="font-semibold">Guest view</h3>
                    <p class="mt-1">Sign in to unlock the secure identity panel and authorized endpoint data.</p>
                    <div class="mt-3 flex flex-wrap gap-2">
                        <button class="rounded border border-amber-300 px-3 py-2 text-sm font-medium text-amber-900 hover:bg-amber-100"
                                @onclick="GoToLogin">
                            Login
                        </button>
                        <button class="rounded bg-amber-900 px-3 py-2 text-sm font-medium text-white hover:bg-amber-700"
                                @onclick="GoToRegister">
                            Register
                        </button>
                    </div>
                </div>
            }
        }
    </section>
</div>

@code {
    [Inject] private IIdentityShowcaseApi IdentityShowcaseApi { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private bool _identityLoading = true;
    private string? _identityError;
    private IdentityShowcasePublicInfo _publicInfo = new()
    {
        AppName = "BlazorAutoApp",
        Message = "Identity showcase has not loaded yet.",
        ServerTimeUtc = DateTimeOffset.UtcNow
    };
    private IdentityShowcaseSecureInfo? _secureInfo;
    private bool _adminProbeLoading;
    private IdentityShowcaseAdminProbeResponse? _adminProbeResult;

    protected override async Task OnInitializedAsync()
    {
        await RefreshIdentityShowcaseAsync();
    }

    private async Task RefreshIdentityShowcaseAsync()
    {
        _identityLoading = true;
        _identityError = null;
        _adminProbeLoading = false;
        _adminProbeResult = null;
        try
        {
            _publicInfo = await IdentityShowcaseApi.GetPublicAsync();
            _secureInfo = await IdentityShowcaseApi.GetSecureAsync();
        }
        catch (Exception ex)
        {
            _identityError = $"Unable to load IdentityShowcase right now: {ex.Message}";
            _secureInfo = null;
        }
        finally
        {
            _identityLoading = false;
        }
    }

    private async Task RunAdminProbeAsync()
    {
        _adminProbeLoading = true;
        try
        {
            _adminProbeResult = await IdentityShowcaseApi.GetAdminProbeAsync();
        }
        finally
        {
            _adminProbeLoading = false;
        }
    }

    private void GoToLogin()
    {
        Nav.NavigateTo("/Identity/Account/Login", forceLoad: true);
    }

    private void GoToRegister()
    {
        Nav.NavigateTo("/Identity/Account/Register", forceLoad: true);
    }

    private void GoToAccount()
    {
        Nav.NavigateTo("/Identity/Account/Manage", forceLoad: true);
    }
}
