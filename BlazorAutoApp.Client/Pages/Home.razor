@page "/"

<PageTitle>Home</PageTitle>

<h1 class="text-3xl font-bold text-black">Welcome to a sample site showcasing Blazor Auto mode with TUS file upload protocol</h1>

<p class="text-black mb-4">Current rendering mode: @RendererInfo.Name</p>

<div class="mt-3">
    <button class="bg-blue-600 text-white px-3 py-1 rounded" @onclick="StartInspection">
        Start New Inspection
    </button>
</div>

<div class="mt-6">
    <button class="bg-gray-800 text-white px-3 py-2 rounded" @onclick="GoToAdminFlow">Admin: Open Demo Inspection Flow</button>
    <div class="text-gray-600 mt-1">Opens a pre-seeded flow.</div>
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private static readonly Guid AdminFlowId = Guid.Parse("11111111-1111-1111-1111-111111111111");

    private void StartInspection()
    {
        var id = Guid.NewGuid();
        Nav.NavigateTo($"/inspection/{id}/flow");
    }

    private void GoToAdminFlow()
    {
        Nav.NavigateTo($"/inspection/{AdminFlowId}/flow");
    }
}
