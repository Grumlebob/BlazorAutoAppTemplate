@page "/inspection/{Id:guid}/flow"
@using BlazorAutoApp.Core.Features.Inspections.HullImages.Contracts
@using BlazorAutoApp.Core.Features.Inspections.HullImages.Domain
@using BlazorAutoApp.Core.Features.Inspections.HullImages.UseCases.CreateHullImage
@using BlazorAutoApp.Core.Features.Inspections.HullImages.UseCases.GetHullImage
@using BlazorAutoApp.Core.Features.Inspections.HullImages.UseCases.GetHullImages
@using BlazorAutoApp.Core.Features.Inspections.VesselPartDetails.Contracts
@using BlazorAutoApp.Core.Features.Inspections.VesselPartDetails.Domain
@using BlazorAutoApp.Core.Features.Inspections.VesselPartDetails.UseCases.GetVesselPartDetails
@using BlazorAutoApp.Core.Features.Inspections.VesselPartDetails.UseCases.UpsertVesselPartDetails

<PageTitle>Inspection Flow</PageTitle>

<h1 class="text-2xl font-semibold text-black mb-4">Inspection Flow</h1>
<EditForm Model="@this">
    <div class="max-w-5xl space-y-5">
        <div>
            <label class="block text-black mb-1">Inspection Type</label>
            <select class="border rounded w-full px-3 py-2 text-black" value="@_type" @onchange="OnTypeChanged">
                @foreach (var it in Enum.GetValues<BlazorAutoApp.Core.Features.Inspections.InspectionFlow.Domain.InspectionType>())
                {
                    <option value="@it">@it</option>
                }
            </select>
        </div>
        <div>
            <label class="block text-black mb-1">Vessel Name</label>
            <input class="border rounded w-full px-3 py-2 text-black" value="@_vesselName" @onchange="OnVesselNameChanged" placeholder="Enter vessel name" />
        </div>

        <div class="flex flex-wrap items-center gap-2 text-sm font-medium" style="margin-top: 0.75rem;">
            <span class="badge rounded-pill" style="background-color:#ffffff;color:#111111;border:1px solid #111111;padding:0.45rem 0.75rem;">
                Incomplete: @IncompletePartCount
            </span>
            <span class="badge rounded-pill" style="background-color:#fef3c7;color:#92400e;border:1px solid #f59e0b;padding:0.45rem 0.75rem;">
                Partially Completed: @PartiallyCompletedPartCount
            </span>
            <span class="badge rounded-pill" style="background-color:#d1fae5;color:#065f46;border:1px solid #10b981;padding:0.45rem 0.75rem;">
                Fully Completed: @FullyCompletedPartCount
            </span>
            <span class="badge rounded-pill" style="background-color:#dbeafe;color:#1e3a8a;border:1px solid #3b82f6;padding:0.45rem 0.75rem;">
                Inspection Not Needed: @InspectionNotNeededPartCount
            </span>
        </div>

        <div class="mt-2">
            <div class="inline-flex flex-wrap rounded border border-slate-300 overflow-hidden">
                <button
                    type="button"
                    class="@GetAngleButtonClass(FlowAngle.Starboard)"
                    @onclick="() => SetAngle(FlowAngle.Starboard)">
                    Starboard
                </button>
                <button
                    type="button"
                    class="@GetAngleButtonClass(FlowAngle.Port)"
                    @onclick="() => SetAngle(FlowAngle.Port)">
                    Port
                </button>
                <button
                    type="button"
                    class="@GetAngleButtonClass(FlowAngle.FlatBottom)"
                    @onclick="() => SetAngle(FlowAngle.FlatBottom)">
                    Flat Bottom
                </button>
                <button
                    type="button"
                    class="@GetAngleButtonClass(FlowAngle.Rudder)"
                    @onclick="() => SetAngle(FlowAngle.Rudder)">
                    Rudder
                </button>
                <button
                    type="button"
                    class="@GetAngleButtonClass(FlowAngle.Propeller)"
                    @onclick="() => SetAngle(FlowAngle.Propeller)">
                    Propeller
                </button>
                <button
                    type="button"
                    class="@GetAngleButtonClass(FlowAngle.Other)"
                    @onclick="() => SetAngle(FlowAngle.Other)">
                    Other
                </button>
            </div>
        </div>

        <ImageSegmentToggle
            ImagePath="@CurrentImagePath"
            Columns="@CurrentColumns"
            GridRows="@CurrentGridRows"
            Segments="@CurrentSegments"
            ActiveIndex="@GetActiveIndex(CurrentBindings)"
            PartialIndices="@GetPartialIndices(CurrentBindings)"
            CompletedIndices="@GetCompletedIndices(CurrentBindings)"
            NotNeededIndices="@GetNotNeededIndices(CurrentBindings)"
            OnActiveIndexChanged="OnCurrentViewActiveChanged" />

        @if (_activePartCode is null)
        {
            <div class="rounded border border-slate-300 bg-slate-50 px-3 py-3 text-slate-700">
                Click a ship segment to start that vessel-part inspection.
            </div>
        }
        else
        {
            <div class="rounded border border-slate-300 bg-white px-3 py-3">
                <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
                    <div class="text-black font-semibold">Vessel Part Details: @ActivePartLabel</div>
                    <div class="mt-2 flex flex-wrap items-center gap-2">
                        <button
                            type="button"
                            class="rounded border border-blue-300 px-3 py-1 text-sm font-medium text-blue-700 hover:bg-blue-50 disabled:opacity-50 disabled:cursor-not-allowed"
                            disabled="@(!CanMarkActivePartAsNotNeeded)"
                            @onclick="MarkActivePartAsInspectionNotNeededAsync">
                            Part does not need inspection
                        </button>
                        <button
                            type="button"
                            class="rounded border border-red-300 px-3 py-1 text-sm font-medium text-red-700 hover:bg-red-50"
                            @onclick="RemoveActivePartAsync">
                            Clear information for part
                        </button>
                    </div>
                </div>

                @if (TryGetActiveVesselPartId(out var activeVesselPartId))
                {
                    <VesselPartForm
                        VesselPartId="@activeVesselPartId"
                        ShowContainer="false"
                        ShowTitle="false"
                        OnSaved="OnActivePartSavedAsync"
                        OnImagesChanged="OnActivePartImagesChangedAsync" />
                }
                else
                {
                    <div class="text-gray-600">Saving to create part container...</div>
                }
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(_error)) { <div class="text-red-600">@_error</div> }
        @if (!string.IsNullOrWhiteSpace(_info)) { <div class="text-green-700">@_info</div> }
    </div>
</EditForm>

@code {
    private enum FlowAngle
    {
        Starboard = 0,
        Port = 1,
        FlatBottom = 2,
        Rudder = 3,
        Propeller = 4,
        Other = 5
    }

    private sealed record SegmentBinding(string Label, string? PartCode, bool IsInteractive = true);
    private record VesselPartVm(int? Id, string PartCode);
    private const string InspectionNotNeededMarker = "__INSPECTION_NOT_NEEDED__";

    private static readonly SegmentBinding[] _starboardBindings =
    [
        new("", null, false),
        CreateBinding("aft::Starboard"),
        CreateBinding("midships::Rear Starboard"),
        CreateBinding("midships::Front Starboard"),
        CreateBinding("bow::Starboard")
    ];

    private static readonly SegmentBinding[] _portBindings =
    [
        new("", null, false),
        CreateBinding("aft::Port"),
        CreateBinding("midships::Rear Port"),
        CreateBinding("midships::Front Port"),
        CreateBinding("bow::Port")
    ];

    private static readonly SegmentBinding[] _flatBottomBindings =
    [
        CreateBinding("aft::Flat Bottom"),
        CreateBinding("midships::Rear Flat Bottom"),
        CreateBinding("midships::Front Flat Bottom"),
        CreateBinding("bow::Flat Bottom")
    ];

    private static readonly SegmentBinding[] _rudderBindings =
    [
        CreateBinding("rudder::Port-Up"),
        CreateBinding("rudder::Port-Down"),
        CreateBinding("rudder::Starboard-Up"),
        CreateBinding("rudder::Starboard-Down")
    ];

    private static readonly SegmentBinding[] _propellerBindings =
    [
        CreateBinding("propeller::Propeller"),
        CreateBinding("propeller::Rope Guard"),
        CreateBinding("propeller::Shaft")
    ];

    private static readonly SegmentBinding[] _otherBindings =
    [
        CreateBinding("other::Sea Chest Grating"),
        CreateBinding("other::Bilge Keels"),
        CreateBinding("other::ICCP"),
        CreateBinding("other::Aft Thruster"),
        CreateBinding("other::Keel Block Mark")
    ];

    private static readonly string[] _orderedMappedCodes = _starboardBindings
        .Concat(_portBindings)
        .Concat(_flatBottomBindings)
        .Concat(_rudderBindings)
        .Concat(_propellerBindings)
        .Concat(_otherBindings)
        .Select(x => x.PartCode)
        .Where(code => !string.IsNullOrWhiteSpace(code))
        .Select(code => code!)
        .Distinct(StringComparer.Ordinal)
        .ToArray();

    private static readonly HashSet<string> _mappedPartCodes = _orderedMappedCodes.ToHashSet(StringComparer.Ordinal);

    private static readonly IReadOnlyDictionary<string, string> _partLabelByCode = _starboardBindings
        .Concat(_portBindings)
        .Concat(_flatBottomBindings)
        .Concat(_rudderBindings)
        .Concat(_propellerBindings)
        .Concat(_otherBindings)
        .Where(x => !string.IsNullOrWhiteSpace(x.PartCode))
        .GroupBy(x => x.PartCode!, StringComparer.Ordinal)
        .ToDictionary(g => g.Key, g => g.First().Label, StringComparer.Ordinal);

    [Parameter] public Guid Id { get; set; }
    [Inject] private IInspectionFlowApi FlowApi { get; set; } = default!;
    [Inject] private IVesselPartDetailsApi VesselPartDetailsApi { get; set; } = default!;
    [Inject] private IHullImagesApi HullImagesApi { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private readonly int[] _sideRows = [8, 92];
    private readonly int[] _flatBottomRows = [100];
    private readonly int[] _rudderRows = [100];
    private readonly int[] _propellerRows = [100];
    private readonly int[] _otherRows = [100];
    private List<ImageSegmentToggle.Segment> StarboardSegments = CreateSegments(_starboardBindings);
    private List<ImageSegmentToggle.Segment> PortSegments = CreateSegments(_portBindings);
    private List<ImageSegmentToggle.Segment> FlatBottomSegments = CreateSegments(_flatBottomBindings);
    private List<ImageSegmentToggle.Segment> RudderSegments = CreateSegments(_rudderBindings);
    private List<ImageSegmentToggle.Segment> PropellerSegments = CreateSegments(_propellerBindings);
    private List<ImageSegmentToggle.Segment> OtherSegments = CreateSegments(_otherBindings);
    private FlowAngle _angle = FlowAngle.Starboard;

    private string _vesselName = string.Empty;
    private BlazorAutoApp.Core.Features.Inspections.InspectionFlow.Domain.InspectionType _type = BlazorAutoApp.Core.Features.Inspections.InspectionFlow.Domain.InspectionType.GoProInspection;
    private HashSet<string> _selectedPartCodes = new(StringComparer.Ordinal);
    private HashSet<string> _partiallyCompletedPartCodes = new(StringComparer.Ordinal);
    private HashSet<string> _completedPartCodes = new(StringComparer.Ordinal);
    private HashSet<string> _inspectionNotNeededPartCodes = new(StringComparer.Ordinal);
    private string? _activePartCode;
    private List<VesselPartVm> _vesselParts = new();
    private string? _error;
    private string? _info;
    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync(bool allowAutoPrune = true)
    {
        try
        {
            var model = await FlowApi.GetAsync(Id);
            _vesselName = model.VesselName ?? string.Empty;
            _type = model.InspectionType;

            var validParts = model.VesselParts
                .Where(vp => _mappedPartCodes.Contains(vp.PartCode))
                .ToList();
            var removedMismatches = validParts.Count != model.VesselParts.Count;

            _selectedPartCodes = validParts.Select(vp => vp.PartCode).ToHashSet(StringComparer.Ordinal);
            _vesselParts = validParts
                .Select(vp => new VesselPartVm(vp.Id, vp.PartCode))
                .ToList();
            _activePartCode = ResolveActivePartCode(_activePartCode);
            await RefreshPartProgressCodesAsync();

            if (allowAutoPrune && removedMismatches)
            {
                await SaveFlowAsync();
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private Task OnVesselNameChanged(ChangeEventArgs e)
    {
        _vesselName = e?.Value?.ToString() ?? string.Empty;
        return SaveFlowAsync();
    }

    private Task OnTypeChanged(ChangeEventArgs e)
    {
        var s = e?.Value?.ToString();
        if (!string.IsNullOrWhiteSpace(s) && Enum.TryParse<BlazorAutoApp.Core.Features.Inspections.InspectionFlow.Domain.InspectionType>(s, out var t))
        {
            _type = t;
            return SaveFlowAsync();
        }
        return Task.CompletedTask;
    }

    private IReadOnlyList<SegmentBinding> CurrentBindings => _angle switch
    {
        FlowAngle.Starboard => _starboardBindings,
        FlowAngle.Port => _portBindings,
        FlowAngle.FlatBottom => _flatBottomBindings,
        FlowAngle.Rudder => _rudderBindings,
        FlowAngle.Propeller => _propellerBindings,
        FlowAngle.Other => _otherBindings,
        _ => _starboardBindings
    };

    private List<ImageSegmentToggle.Segment> CurrentSegments => _angle switch
    {
        FlowAngle.Starboard => StarboardSegments,
        FlowAngle.Port => PortSegments,
        FlowAngle.FlatBottom => FlatBottomSegments,
        FlowAngle.Rudder => RudderSegments,
        FlowAngle.Propeller => PropellerSegments,
        FlowAngle.Other => OtherSegments,
        _ => StarboardSegments
    };

    private int[] CurrentGridRows => _angle switch
    {
        FlowAngle.Starboard => _sideRows,
        FlowAngle.Port => _sideRows,
        FlowAngle.FlatBottom => _flatBottomRows,
        FlowAngle.Rudder => _rudderRows,
        FlowAngle.Propeller => _propellerRows,
        FlowAngle.Other => _otherRows,
        _ => _sideRows
    };

    private int CurrentColumns => _angle switch
    {
        FlowAngle.Starboard => 4,
        FlowAngle.Port => 4,
        FlowAngle.FlatBottom => 4,
        FlowAngle.Rudder => 4,
        FlowAngle.Propeller => 3,
        FlowAngle.Other => 3,
        _ => 4
    };

    private string CurrentImagePath => _angle switch
    {
        FlowAngle.FlatBottom => "port_hull.PNG",
        _ => "starboard_hull.PNG"
    };

    private Task OnCurrentViewActiveChanged(int index) => ActivateSegmentAsync(CurrentBindings, index);

    private void SetAngle(FlowAngle angle) => _angle = angle;

    private string GetAngleButtonClass(FlowAngle angle)
    {
        var isActive = _angle == angle;
        return isActive
            ? "bg-blue-600 text-white px-3 py-1 text-sm font-medium"
            : "bg-white text-slate-800 px-3 py-1 text-sm font-medium hover:bg-slate-50";
    }

    private async Task ActivateSegmentAsync(IReadOnlyList<SegmentBinding> bindings, int index)
    {
        if (index < 0 || index >= bindings.Count)
        {
            return;
        }

        var partCode = bindings[index].PartCode;
        if (string.IsNullOrWhiteSpace(partCode))
        {
            return;
        }

        _activePartCode = partCode;

        if (_selectedPartCodes.Contains(partCode))
        {
            return;
        }

        _selectedPartCodes.Add(partCode);
        if (!_vesselParts.Any(v => string.Equals(v.PartCode, partCode, StringComparison.Ordinal)))
        {
            _vesselParts.Add(new VesselPartVm(null, partCode));
        }

        await SaveFlowAsync();
    }

    private async Task RemoveActivePartAsync()
    {
        if (_activePartCode is null)
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Remove '{ActivePartLabel}' from this inspection?");
        if (!confirmed)
        {
            return;
        }

        _selectedPartCodes.Remove(_activePartCode);
        _partiallyCompletedPartCodes.Remove(_activePartCode);
        _completedPartCodes.Remove(_activePartCode);
        _inspectionNotNeededPartCodes.Remove(_activePartCode);
        _vesselParts.RemoveAll(v => string.Equals(v.PartCode, _activePartCode, StringComparison.Ordinal));
        _activePartCode = ResolveActivePartCode(null);

        await SaveFlowAsync();
    }

    private async Task MarkActivePartAsInspectionNotNeededAsync()
    {
        if (_activePartCode is null || !TryGetActiveVesselPartId(out var vesselPartId))
        {
            return;
        }

        _error = null;
        _info = null;
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Set '{ActivePartLabel}' as inspection not needed?");
        if (!confirmed)
        {
            return;
        }

        try
        {
            var details = await VesselPartDetailsApi.GetAsync(vesselPartId);
            var response = await VesselPartDetailsApi.UpsertAsync(new UpsertVesselPartDetailsRequest
            {
                InspectionVesselPartId = vesselPartId,
                Fouling = details.Fouling,
                Coating = details.Coating,
                Hull = details.Hull,
                Rating = new HullRatingDto
                {
                    Rating = details.Rating.Rating,
                    Rationale = InspectionNotNeededMarker
                },
                Notes = details.Notes
            });

            if (!response.Success)
            {
                _error = response.Error ?? "Unable to mark part as inspection not needed.";
                return;
            }

            await RefreshPartProgressForVesselPartAsync(vesselPartId);
            _info = $"'{ActivePartLabel}' marked as inspection not needed.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SaveFlowAsync()
    {
        _error = null; _info = null;
        try
        {
            var payload = new BlazorAutoApp.Core.Features.Inspections.InspectionFlow.UseCases.UpsertInspectionFlow.UpsertInspectionFlowRequest
            {
                Id = Id,
                VesselName = _vesselName,
                InspectionType = _type,
                VesselParts = _selectedPartCodes.Select(code =>
                {
                    var existing = _vesselParts.FirstOrDefault(v => string.Equals(v.PartCode, code, StringComparison.Ordinal));
                    return new BlazorAutoApp.Core.Features.Inspections.InspectionFlow.Contracts.InspectionVesselPartDto
                    {
                        Id = existing?.Id,
                        PartCode = code
                    };
                }).ToList()
            };
            var res = await FlowApi.UpsertAsync(payload);
            if (res.Success)
            {
                await LoadAsync(allowAutoPrune: false);
            }
            else
            {
                _error = res.Error;
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private string ActivePartLabel
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_activePartCode))
            {
                return "No active part";
            }

            return _partLabelByCode.TryGetValue(_activePartCode, out var label)
                ? label
                : _activePartCode;
        }
    }

    private int GetActiveIndex(IReadOnlyList<SegmentBinding> bindings)
    {
        if (string.IsNullOrWhiteSpace(_activePartCode))
        {
            return -1;
        }

        for (var i = 0; i < bindings.Count; i++)
        {
            if (string.Equals(bindings[i].PartCode, _activePartCode, StringComparison.Ordinal))
            {
                return i;
            }
        }
        return -1;
    }

    private IReadOnlySet<int> GetCompletedIndices(IReadOnlyList<SegmentBinding> bindings)
    {
        var set = new HashSet<int>();
        for (var i = 0; i < bindings.Count; i++)
        {
            var code = bindings[i].PartCode;
            if (!string.IsNullOrWhiteSpace(code) && _completedPartCodes.Contains(code))
            {
                set.Add(i);
            }
        }
        return set;
    }

    private IReadOnlySet<int> GetPartialIndices(IReadOnlyList<SegmentBinding> bindings)
    {
        var set = new HashSet<int>();
        for (var i = 0; i < bindings.Count; i++)
        {
            var code = bindings[i].PartCode;
            if (!string.IsNullOrWhiteSpace(code) && _partiallyCompletedPartCodes.Contains(code))
            {
                set.Add(i);
            }
        }
        return set;
    }

    private IReadOnlySet<int> GetNotNeededIndices(IReadOnlyList<SegmentBinding> bindings)
    {
        var set = new HashSet<int>();
        for (var i = 0; i < bindings.Count; i++)
        {
            var code = bindings[i].PartCode;
            if (!string.IsNullOrWhiteSpace(code) && _inspectionNotNeededPartCodes.Contains(code))
            {
                set.Add(i);
            }
        }
        return set;
    }

    private bool TryGetActiveVesselPartId(out int id)
    {
        id = default;
        if (string.IsNullOrWhiteSpace(_activePartCode))
        {
            return false;
        }

        var vesselPart = _vesselParts.FirstOrDefault(v => string.Equals(v.PartCode, _activePartCode, StringComparison.Ordinal));
        if (vesselPart?.Id is int vesselPartId)
        {
            id = vesselPartId;
            return true;
        }

        return false;
    }

    private bool CanMarkActivePartAsNotNeeded => TryGetActiveVesselPartId(out _);

    private string? ResolveActivePartCode(string? preferredPartCode)
    {
        if (!string.IsNullOrWhiteSpace(preferredPartCode) && _selectedPartCodes.Contains(preferredPartCode))
        {
            return preferredPartCode;
        }

        foreach (var code in _orderedMappedCodes)
        {
            if (_selectedPartCodes.Contains(code))
            {
                return code;
            }
        }

        return null;
    }

    private static List<ImageSegmentToggle.Segment> CreateSegments(IEnumerable<SegmentBinding> bindings)
    {
        return bindings
            .Select(binding => new ImageSegmentToggle.Segment
            {
                Label = binding.Label,
                IsInteractive = binding.IsInteractive
            })
            .ToList();
    }

    private int FullyCompletedPartCount => _completedPartCodes.Count;
    private int PartiallyCompletedPartCount => _partiallyCompletedPartCodes.Count;
    private int InspectionNotNeededPartCount => _inspectionNotNeededPartCodes.Count;
    private int IncompletePartCount => Math.Max(0, _mappedPartCodes.Count - FullyCompletedPartCount - PartiallyCompletedPartCount - InspectionNotNeededPartCount);

    private async Task OnActivePartSavedAsync(int vesselPartId)
    {
        await RefreshPartProgressForVesselPartAsync(vesselPartId);
    }

    private async Task OnActivePartImagesChangedAsync(int vesselPartId)
    {
        await RefreshPartProgressForVesselPartAsync(vesselPartId);
    }

    private async Task RefreshPartProgressForVesselPartAsync(int vesselPartId)
    {
        var vesselPart = _vesselParts.FirstOrDefault(v => v.Id == vesselPartId);
        if (vesselPart is null)
        {
            return;
        }

        var state = await GetPartProgressStateAsync(vesselPartId);
        ApplyPartProgress(vesselPart.PartCode, state);
    }

    private async Task RefreshPartProgressCodesAsync()
    {
        var selectedPartEntries = _vesselParts
            .Where(v => v.Id is int && _selectedPartCodes.Contains(v.PartCode))
            .ToList();
        if (selectedPartEntries.Count == 0)
        {
            _partiallyCompletedPartCodes.Clear();
            _completedPartCodes.Clear();
            _inspectionNotNeededPartCodes.Clear();
            return;
        }

        _partiallyCompletedPartCodes.Clear();
        _completedPartCodes.Clear();
        _inspectionNotNeededPartCodes.Clear();

        var completionChecks = selectedPartEntries.Select(async x =>
            (x.PartCode, State: await GetPartProgressStateAsync(x.Id!.Value))).ToList();
        var completionResults = await Task.WhenAll(completionChecks);
        foreach (var result in completionResults)
        {
            ApplyPartProgress(result.PartCode, result.State);
        }
    }

    private void ApplyPartProgress(string partCode, PartProgressState state)
    {
        _partiallyCompletedPartCodes.Remove(partCode);
        _completedPartCodes.Remove(partCode);
        _inspectionNotNeededPartCodes.Remove(partCode);

        switch (state)
        {
            case PartProgressState.PartiallyCompleted:
                _partiallyCompletedPartCodes.Add(partCode);
                break;
            case PartProgressState.FullyCompleted:
                _completedPartCodes.Add(partCode);
                break;
            case PartProgressState.InspectionNotNeeded:
                _inspectionNotNeededPartCodes.Add(partCode);
                break;
            case PartProgressState.Incomplete:
            default:
                break;
        }
    }

    private async Task<PartProgressState> GetPartProgressStateAsync(int vesselPartId)
    {
        var detailsTask = VesselPartDetailsApi.GetAsync(vesselPartId);
        var imagesTask = HullImagesApi.GetAsync(new GetHullImagesRequest { VesselPartId = vesselPartId });
        try
        {
            await Task.WhenAll(detailsTask, imagesTask);
        }
        catch
        {
            return PartProgressState.Incomplete;
        }

        if (IsInspectionNotNeeded(detailsTask.Result))
        {
            return PartProgressState.InspectionNotNeeded;
        }

        var hasSavedDetails = detailsTask.Result.HasSaved;
        if (!hasSavedDetails)
        {
            return PartProgressState.Incomplete;
        }

        return imagesTask.Result.Items.Count > 0
            ? PartProgressState.FullyCompleted
            : PartProgressState.PartiallyCompleted;
    }

    private enum PartProgressState
    {
        Incomplete = 0,
        PartiallyCompleted = 1,
        FullyCompleted = 2,
        InspectionNotNeeded = 3
    }

    private static bool IsInspectionNotNeeded(GetVesselPartDetailsResponse details)
    {
        return string.Equals(details.Rating.Rationale, InspectionNotNeededMarker, StringComparison.Ordinal);
    }

    private static SegmentBinding CreateBinding(string partCode) => new(FormatLabel(partCode), partCode);

    private static string FormatLabel(string partCode)
    {
        var parts = partCode.Split("::", 2, StringSplitOptions.TrimEntries);
        if (parts.Length != 2)
        {
            return partCode;
        }

        var categoryLabel = parts[0] switch
        {
            "bow" => "Bow",
            "midships" => "Midships",
            "aft" => "Aft",
            "rudder" => "Rudder",
            "propeller" => "Propeller",
            "other" => "Other",
            _ => parts[0]
        };

        return $"{categoryLabel} {parts[1]}";
    }
}

