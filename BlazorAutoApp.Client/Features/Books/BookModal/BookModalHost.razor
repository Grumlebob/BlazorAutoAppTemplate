@implements IDisposable

@inject IBooksApi Books
@inject IAuthorBooksApi AuthorBooks
@inject NavigationManager Nav
@inject UserBookcaseState UserBooks
@inject Microsoft.Extensions.Logging.ILogger<BookModalHost> Logger

@if (_request is not null)
{
    <div @ref="_dialog"
         class="fixed inset-0 z-50 overflow-y-auto bg-transparent px-4 py-6 outline-none"
         role="dialog"
         aria-modal="true"
         aria-labelledby="book-modal-title"
         tabindex="-1"
         data-testid="book-modal"
         @onkeydown="HandleKeyDown">
        <div class="mx-auto flex min-h-full w-[min(calc(100vw-2rem),37rem)] flex-col items-center justify-start">
            @if (_loading)
            {
                <div class="w-full rounded-md border border-gray-200 bg-white px-4 py-3 text-sm font-medium text-gray-700 shadow-sm">
                    Loading book...
                </div>
            }
            else if (_error is not null)
            {
                <div class="w-full rounded-md border border-red-200 bg-white px-4 py-3 text-sm font-medium text-red-700 shadow-sm">
                    <div class="mb-2 flex justify-end">
                        <a data-testid="book-back"
                           class="inline-flex items-center rounded-md border border-red-200 bg-white px-3 py-2 text-sm font-bold text-red-700 no-underline shadow-sm hover:bg-red-50 hover:text-red-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600"
                           href="/books">Close</a>
                    </div>
                    <h1 id="book-modal-title" class="mb-1 text-lg font-bold text-red-700">Book not found.</h1>
                    <p>@_error</p>
                </div>
            }
            else if (_request.Mode is BookModalMode.View && _viewModel is not null)
            {
                <h1 id="book-modal-title" class="sr-only">@_viewModel.Title</h1>
                <BookPageView Title="@_viewModel.Title"
                              Author="@_viewModel.Author"
                              Url="@_viewModel.Url"
                              EditHref="@UserEditHref"
                              CloseHref="/books"
                              CanDelete="@CanDelete"
                              IsDeleteConfirming="@_confirmingDelete"
                              IsDeleteBusy="@_deleting"
                              OnDeleteRequest="RequestDelete"
                              OnDeleteConfirm="DeleteAsync"
                              OnDeleteCancel="CancelDelete" />
            }
            else if (_request.Mode is BookModalMode.Create or BookModalMode.Edit)
            {
                <h1 id="book-modal-title" class="sr-only">@EditorHeading</h1>
                <BookPageEditor Model="_editorModel"
                                Heading="@EditorHeading"
                                SubmitLabel="Close and save"
                                CancelLabel="Close"
                                CancelHref="/books"
                                Error="@_saveError"
                                IsBusy="@_saving"
                                OnValidSubmit="SaveAsync" />
            }
        </div>
    </div>
}

@code {
    private ElementReference _dialog;
    private BookModalRouteState? _request;
    private BookModalViewModel? _viewModel;
    private BookPageEditorModel _editorModel = new();
    private bool _loading;
    private bool _saving;
    private bool _deleting;
    private bool _focusPending;
    private bool _confirmingDelete;
    private int _loadVersion;
    private CancellationTokenSource? _loadCancellation;
    private CancellationTokenSource? _operationCancellation;
    private string? _editorModelRequestKey;
    private string? _error;
    private string? _saveError;

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private string? UserEditHref =>
        _request is { Source: BookModalSource.User, Mode: BookModalMode.View, UserBookId: not null }
            ? $"/books?bookId={_request.UserBookId.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}&bookMode=edit"
            : null;

    private string EditorHeading => _request?.Mode is BookModalMode.Create ? "Add Book" : "Edit Book";

    private bool CanDelete => _request is { Source: BookModalSource.User, UserBookId: not null };

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += HandleLocationChanged;
        await LoadFromUriAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusPending && _request is not null)
        {
            _focusPending = false;
            await _dialog.FocusAsync();
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args) =>
        _ = InvokeAsync(LoadFromUriAsync);

    private async Task LoadFromUriAsync()
    {
        var loadCancellation = StartLoad(out var version);
        CancelActiveOperation();
        var cancellationToken = loadCancellation.Token;
        var request = BookModalRouteState.Parse(Nav.Uri);
        _request = request;
        _viewModel = null;
        _error = null;
        _saveError = null;
        _saving = false;
        _deleting = false;
        _confirmingDelete = false;

        if (request is null)
        {
            _loading = false;
            _editorModelRequestKey = null;
            StateHasChanged();
            CompleteLoad(loadCancellation);
            return;
        }

        _loading = true;
        _focusPending = true;
        StateHasChanged();

        try
        {
            if (request.Mode is BookModalMode.Create or BookModalMode.Edit)
            {
                var authState = await AuthenticationStateTask;
                if (!IsCurrentLoad(version, cancellationToken))
                {
                    return;
                }

                if (authState.User.Identity?.IsAuthenticated != true)
                {
                    var returnUrl = Uri.EscapeDataString(Nav.Uri);
                    Nav.NavigateTo($"Account/Login?returnUrl={returnUrl}", forceLoad: true);
                    return;
                }
            }

            switch (request)
            {
                case { Source: BookModalSource.Author, AuthorBookId: not null }:
                    _editorModelRequestKey = null;
                    await LoadAuthorBookAsync(request.AuthorBookId.Value, version, cancellationToken);
                    break;
                case { Source: BookModalSource.User, Mode: BookModalMode.Create }:
                    EnsureCreateEditorModel(request);
                    break;
                case { Source: BookModalSource.User, UserBookId: not null }:
                    await LoadUserBookAsync(request.UserBookId.Value, request, version, cancellationToken);
                    break;
                default:
                    _error = "This book link is invalid.";
                    break;
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            if (IsCurrentLoad(version, cancellationToken))
            {
                Logger.LogWarning(ex, "Book modal load failed for {BookModalUri}", Nav.Uri);
                _error = "Book details could not be loaded.";
            }
        }
        finally
        {
            if (IsCurrentLoad(version, cancellationToken))
            {
                _loading = false;
                StateHasChanged();
            }

            CompleteLoad(loadCancellation);
        }
    }

    private async Task LoadAuthorBookAsync(int authorBookId, int version, CancellationToken cancellationToken)
    {
        if (_request?.Mode is not BookModalMode.View)
        {
            _error = "Author books can only be viewed.";
            return;
        }

        var book = await AuthorBooks.GetByIdAsync(new GetAuthorBookRequest { Id = authorBookId }, cancellationToken);
        if (!IsCurrentLoad(version, cancellationToken))
        {
            return;
        }

        if (book is null)
        {
            _error = "This book could not be found.";
            return;
        }

        _viewModel = new BookModalViewModel(book.Title, book.Author, book.Url);
    }

    private async Task LoadUserBookAsync(
        int id,
        BookModalRouteState request,
        int version,
        CancellationToken cancellationToken)
    {
        var response = await Books.GetByIdAsync(new GetBookRequest { Id = id }, cancellationToken);
        if (!IsCurrentLoad(version, cancellationToken))
        {
            return;
        }

        if (response is null)
        {
            _error = "This book could not be found.";
            return;
        }

        if (request.Mode is BookModalMode.Edit)
        {
            var key = request.EditorRequestKey;
            if (!string.Equals(_editorModelRequestKey, key, StringComparison.Ordinal))
            {
                _editorModel = new BookPageEditorModel
                {
                    Title = response.Title,
                    Author = response.Author,
                    Url = response.Url
                };
                _editorModelRequestKey = key;
            }

            return;
        }

        _editorModelRequestKey = null;
        _viewModel = new BookModalViewModel(response.Title, response.Author, response.Url);
    }

    private async Task SaveAsync(BookPageEditorModel model)
    {
        if (_saving)
        {
            return;
        }

        var request = _request;
        if (request is null)
        {
            return;
        }

        var operation = StartOperation();
        var cancellationToken = operation.Token;
        _saving = true;
        _saveError = null;
        StateHasChanged();

        try
        {
            if (request.Mode is BookModalMode.Create)
            {
                var created = await Books.CreateAsync(new CreateBookRequest
                {
                    Title = model.Title,
                    Author = NormalizeOptional(model.Author),
                    Url = NormalizeOptional(model.Url)
                }, cancellationToken);
                if (!IsCurrentOperation(operation))
                {
                    return;
                }

                UserBooks.ApplySavedBook(ToBookListItem(created));
            }
            else if (request is { Mode: BookModalMode.Edit, UserBookId: not null })
            {
                var title = model.Title.Trim();
                var author = NormalizeOptional(model.Author);
                var url = NormalizeOptional(model.Url);
                var success = await Books.UpdateAsync(new UpdateBookRequest
                {
                    Id = request.UserBookId.Value,
                    Title = title,
                    Author = author,
                    Url = url
                }, cancellationToken);
                if (!IsCurrentOperation(operation))
                {
                    return;
                }

                if (!success)
                {
                    _saveError = "Book not found.";
                    return;
                }

                UserBooks.ApplySavedBook(new BookListItemResponse
                {
                    Id = request.UserBookId.Value,
                    Title = title,
                    Author = author,
                    Url = url
                });
            }

            Nav.NavigateTo("/books");
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            if (IsCurrentOperation(operation))
            {
                Logger.LogWarning(ex, "Book save failed for {BookModalUri}", Nav.Uri);
                _saveError = "Book could not be saved.";
            }
        }
        finally
        {
            if (IsCurrentOperation(operation))
            {
                _saving = false;
            }

            CompleteOperation(operation);
        }
    }

    private void RequestDelete()
    {
        if (CanDelete)
        {
            _confirmingDelete = true;
        }
    }

    private void CancelDelete() => _confirmingDelete = false;

    private async Task DeleteAsync()
    {
        if (_deleting)
        {
            return;
        }

        var request = _request;
        if (request is not { Source: BookModalSource.User, UserBookId: not null })
        {
            return;
        }

        var operation = StartOperation();
        var cancellationToken = operation.Token;
        _deleting = true;
        _error = null;
        StateHasChanged();

        try
        {
            var deleted = await UserBooks.DeleteAsync(request.UserBookId.Value, cancellationToken);
            if (!IsCurrentOperation(operation))
            {
                return;
            }

            if (deleted)
            {
                Nav.NavigateTo("/books");
                return;
            }

            _error = "Book could not be deleted.";
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            if (IsCurrentOperation(operation))
            {
                Logger.LogWarning(ex, "Book delete failed for {BookModalUri}", Nav.Uri);
                _error = "Book could not be deleted.";
            }
        }
        finally
        {
            if (IsCurrentOperation(operation))
            {
                _deleting = false;
            }

            CompleteOperation(operation);
        }
    }

    private void HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
        {
            Nav.NavigateTo("/books");
        }
    }

    private void EnsureCreateEditorModel(BookModalRouteState request)
    {
        var key = request.EditorRequestKey;
        if (string.Equals(_editorModelRequestKey, key, StringComparison.Ordinal))
        {
            return;
        }

        _editorModel = new BookPageEditorModel();
        _editorModelRequestKey = key;
    }

    private static string? NormalizeOptional(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static BookListItemResponse ToBookListItem(CreateBookResponse response) => new()
    {
        Id = response.Id,
        Title = response.Title,
        Author = response.Author,
        Url = response.Url
    };

    private CancellationTokenSource StartLoad(out int version)
    {
        CancelActiveLoad();
        var cancellation = new CancellationTokenSource();
        _loadCancellation = cancellation;
        version = Interlocked.Increment(ref _loadVersion);
        return cancellation;
    }

    private bool IsCurrentLoad(int version, CancellationToken cancellationToken) =>
        !cancellationToken.IsCancellationRequested && version == Volatile.Read(ref _loadVersion);

    private void CompleteLoad(CancellationTokenSource loadCancellation)
    {
        if (ReferenceEquals(_loadCancellation, loadCancellation))
        {
            _loadCancellation = null;
        }

        loadCancellation.Dispose();
    }

    private void CancelActiveLoad()
    {
        var cancellation = _loadCancellation;
        if (cancellation is null)
        {
            return;
        }

        _loadCancellation = null;
        cancellation.Cancel();
    }

    private CancellationTokenSource StartOperation()
    {
        CancelActiveOperation();
        var cancellation = new CancellationTokenSource();
        _operationCancellation = cancellation;
        return cancellation;
    }

    private bool IsCurrentOperation(CancellationTokenSource operation) =>
        !operation.IsCancellationRequested && ReferenceEquals(_operationCancellation, operation);

    private void CompleteOperation(CancellationTokenSource operation)
    {
        if (ReferenceEquals(_operationCancellation, operation))
        {
            _operationCancellation = null;
        }

        operation.Dispose();
    }

    private void CancelActiveOperation()
    {
        var cancellation = _operationCancellation;
        if (cancellation is null)
        {
            return;
        }

        _operationCancellation = null;
        cancellation.Cancel();
    }

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
        CancelActiveLoad();
        CancelActiveOperation();
    }

    private sealed record BookModalViewModel(string Title, string? Author, string? Url);
}
