@implements IDisposable

@inject IBooksApi Books
@inject NavigationManager Nav
@inject UserBookcaseState UserBooks
@inject IJSRuntime JS

@if (_request is not null)
{
    <div @ref="_dialog"
         class="fixed inset-0 z-50 overflow-y-auto bg-transparent px-4 py-6 outline-none"
         role="dialog"
         aria-modal="true"
         aria-labelledby="book-modal-title"
         tabindex="-1"
        data-testid="book-modal"
         @onkeydown="HandleKeyDown">
        <div class="mx-auto flex min-h-full w-[min(calc(100vw-2rem),37rem)] flex-col items-center justify-start">
            @if (_loading)
            {
                <div class="w-full rounded-md border border-gray-200 bg-white px-4 py-3 text-sm font-medium text-gray-700 shadow-sm">
                    Loading book...
                </div>
            }
            else if (_error is not null)
            {
                <div class="w-full rounded-md border border-red-200 bg-white px-4 py-3 text-sm font-medium text-red-700 shadow-sm">
                    <div class="mb-2 flex justify-end">
                        <a data-testid="book-back"
                           class="inline-flex items-center rounded-md border border-red-200 bg-white px-3 py-2 text-sm font-bold text-red-700 no-underline shadow-sm hover:bg-red-50 hover:text-red-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600"
                           href="/books">Close</a>
                    </div>
                    <h1 id="book-modal-title" class="mb-1 text-lg font-bold text-red-700">Book not found.</h1>
                    <p>@_error</p>
                </div>
            }
            else if (_request.Mode is BookModalMode.View && _viewModel is not null)
            {
                <h1 id="book-modal-title" class="sr-only">@_viewModel.Title</h1>
                <BookPageView Title="@_viewModel.Title"
                              Author="@_viewModel.Author"
                              Url="@_viewModel.Url"
                              EditHref="@UserEditHref"
                              CloseHref="/books"
                              CanDelete="@CanDelete"
                              OnDelete="DeleteAsync" />
            }
            else if (_request.Mode is BookModalMode.Create or BookModalMode.Edit)
            {
                <h1 id="book-modal-title" class="sr-only">@EditorHeading</h1>
                <BookPageEditor Model="_editorModel"
                                Heading="@EditorHeading"
                                SubmitLabel="Close and save"
                                CancelLabel="Close"
                                CancelHref="/books"
                                Error="@_saveError"
                                IsBusy="@_saving"
                                OnValidSubmit="SaveAsync" />
            }
        </div>
    </div>
}

@code {
    private ElementReference _dialog;
    private BookModalRouteState? _request;
    private BookModalViewModel? _viewModel;
    private BookPageEditorModel _editorModel = new();
    private bool _loading;
    private bool _saving;
    private bool _focusPending;
    private int _loadVersion;
    private string? _editorModelRequestKey;
    private string? _error;
    private string? _saveError;

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private string? UserEditHref =>
        _request is { Source: BookModalSource.User, Mode: BookModalMode.View, UserBookId: not null }
            ? $"/books?bookId={_request.UserBookId.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}&bookMode=edit"
            : null;

    private string EditorHeading => _request?.Mode is BookModalMode.Create ? "Add Book" : "Edit Book";

    private bool CanDelete => _request is { Source: BookModalSource.User, UserBookId: not null };

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += HandleLocationChanged;
        await LoadFromUriAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusPending && _request is not null)
        {
            _focusPending = false;
            await _dialog.FocusAsync();
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args) =>
        _ = InvokeAsync(LoadFromUriAsync);

    private async Task LoadFromUriAsync()
    {
        var version = ++_loadVersion;
        _request = BookModalRouteState.Parse(Nav.Uri);
        _viewModel = null;
        _error = null;
        _saveError = null;
        _saving = false;

        if (_request is null)
        {
            _loading = false;
            _editorModelRequestKey = null;
            StateHasChanged();
            return;
        }

        _loading = true;
        _focusPending = true;
        StateHasChanged();

        try
        {
            if (_request.Mode is BookModalMode.Create or BookModalMode.Edit)
            {
                var authState = await AuthenticationStateTask;
                if (authState.User.Identity?.IsAuthenticated != true)
                {
                    var returnUrl = Uri.EscapeDataString(Nav.Uri);
                    Nav.NavigateTo($"Account/Login?returnUrl={returnUrl}", forceLoad: true);
                    return;
                }
            }

            switch (_request)
            {
                case { Source: BookModalSource.Author, AuthorBookId: not null }:
                    _editorModelRequestKey = null;
                    LoadAuthorBook(_request.AuthorBookId.Value);
                    break;
                case { Source: BookModalSource.User, Mode: BookModalMode.Create }:
                    EnsureCreateEditorModel(_request);
                    break;
                case { Source: BookModalSource.User, UserBookId: not null }:
                    await LoadUserBookAsync(_request.UserBookId.Value);
                    break;
                default:
                    _error = "This book link is invalid.";
                    break;
            }
        }
        catch
        {
            _error = "Book details could not be loaded.";
        }
        finally
        {
            if (version == _loadVersion)
            {
                _loading = false;
                StateHasChanged();
            }
        }
    }

    private void LoadAuthorBook(int authorBookId)
    {
        if (_request?.Mode is not BookModalMode.View)
        {
            _error = "Author books can only be viewed.";
            return;
        }

        var book = AuthorBookcaseCatalog.FindById(authorBookId);
        if (book is null)
        {
            _error = "This book could not be found.";
            return;
        }

        _viewModel = new BookModalViewModel(book.Title, book.Author, book.Url);
    }

    private async Task LoadUserBookAsync(int id)
    {
        var response = await Books.GetByIdAsync(new GetBookRequest { Id = id });
        if (response is null)
        {
            _error = "This book could not be found.";
            return;
        }

        if (_request?.Mode is BookModalMode.Edit)
        {
            var key = _request.EditorRequestKey;
            if (!string.Equals(_editorModelRequestKey, key, StringComparison.Ordinal))
            {
                _editorModel = new BookPageEditorModel
                {
                    Title = response.Title,
                    Author = response.Author,
                    Url = response.Url
                };
                _editorModelRequestKey = key;
            }

            return;
        }

        _editorModelRequestKey = null;
        _viewModel = new BookModalViewModel(response.Title, response.Author, response.Url);
    }

    private async Task SaveAsync(BookPageEditorModel model)
    {
        if (_request is null)
        {
            return;
        }

        _saving = true;
        _saveError = null;
        try
        {
            if (_request.Mode is BookModalMode.Create)
            {
                var created = await Books.CreateAsync(new CreateBookRequest
                {
                    Title = model.Title,
                    Author = NormalizeOptional(model.Author),
                    Url = NormalizeOptional(model.Url)
                });

                UserBooks.ApplySavedBook(ToBookListItem(created));
            }
            else if (_request is { Mode: BookModalMode.Edit, UserBookId: not null })
            {
                var title = model.Title.Trim();
                var author = NormalizeOptional(model.Author);
                var url = NormalizeOptional(model.Url);
                var success = await Books.UpdateAsync(new UpdateBookRequest
                {
                    Id = _request.UserBookId.Value,
                    Title = title,
                    Author = author,
                    Url = url
                });

                if (!success)
                {
                    _saveError = "Book not found.";
                    return;
                }

                UserBooks.ApplySavedBook(new BookListItemResponse
                {
                    Id = _request.UserBookId.Value,
                    Title = title,
                    Author = author,
                    Url = url
                });
            }

            Nav.NavigateTo("/books");
        }
        catch
        {
            _saveError = "Book could not be saved.";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (_request is not { Source: BookModalSource.User, UserBookId: not null })
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this book?");
        if (!confirmed)
        {
            return;
        }

        var deleted = await UserBooks.DeleteAsync(_request.UserBookId.Value);
        if (deleted)
        {
            Nav.NavigateTo("/books");
            return;
        }

        _error = "Book could not be deleted.";
    }

    private void HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
        {
            Nav.NavigateTo("/books");
        }
    }

    private void EnsureCreateEditorModel(BookModalRouteState request)
    {
        var key = request.EditorRequestKey;
        if (string.Equals(_editorModelRequestKey, key, StringComparison.Ordinal))
        {
            return;
        }

        _editorModel = new BookPageEditorModel();
        _editorModelRequestKey = key;
    }

    private static string? NormalizeOptional(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static BookListItemResponse ToBookListItem(CreateBookResponse response) => new()
    {
        Id = response.Id,
        Title = response.Title,
        Author = response.Author,
        Url = response.Url
    };

    public void Dispose() => Nav.LocationChanged -= HandleLocationChanged;

    private sealed record BookModalViewModel(string Title, string? Author, string? Url);
}
