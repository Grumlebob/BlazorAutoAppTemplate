@page "/books/{Id:int}/edit"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@inject NavigationManager Nav

<PageTitle>Edit Book</PageTitle>

<h1 class="sr-only">Opening edit book</h1>

@code {
    [Parameter]
    public int Id { get; set; }

    protected override void OnParametersSet() =>
        Nav.NavigateTo($"/books?bookSource=user&bookId={Id.ToString(System.Globalization.CultureInfo.InvariantCulture)}&bookMode=edit", forceLoad: false, replace: true);
}
