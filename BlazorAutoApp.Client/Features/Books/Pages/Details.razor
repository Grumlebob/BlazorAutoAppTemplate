@page "/books/{Id:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@inject NavigationManager Nav

<PageTitle>Book</PageTitle>

<h1 class="sr-only">Opening book</h1>

@code {
    [Parameter]
    public int Id { get; set; }

    protected override void OnParametersSet() =>
        Nav.NavigateTo($"/books?bookId={Id.ToString(System.Globalization.CultureInfo.InvariantCulture)}&bookMode=view", forceLoad: false, replace: true);
}
