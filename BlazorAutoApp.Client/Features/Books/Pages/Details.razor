@page "/books/{Id:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@inject IBooksApi Books

<PageTitle>Book Details</PageTitle>

<h1 class="text-2xl font-semibold mb-2">Book Details</h1>

@if (_loading)
{
    <p>Loading...</p>
}
else if (_error is not null)
{
    <p class="text-red-600">@_error</p>
}
else if (_book is null)
{
    <p>Book not found.</p>
}
else
{
    <div class="rounded border border-gray-200 bg-white shadow-sm p-4">
        <h2 class="text-xl font-semibold text-gray-900">@_book.Title</h2>
        <div class="text-sm text-gray-600 mt-1">Author: @(string.IsNullOrWhiteSpace(_book.Author) ? "Unknown author" : _book.Author)</div>
        @if (!string.IsNullOrWhiteSpace(_book.Url))
        {
            <a data-testid="book-url-link" class="mt-2 inline-flex text-sm font-semibold text-blue-700 hover:text-blue-900" href="@_book.Url" target="_blank" rel="noopener noreferrer">Open URL</a>
        }
    </div>
}

@if (!_loading)
{
    <a data-testid="book-back" class="mt-3 inline-flex items-center rounded-md border border-gray-400 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" href="/books">Back</a>
}

@code {
    [Parameter] public int Id { get; set; }

    private bool _loading = true;
    private string? _error;
    private GetBookResponse? _book;

    [PersistentState]
    public int? PersistedBookId { get; set; }

    [PersistentState]
    public GetBookResponse? PersistedBook { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            if (PersistedBookId == Id)
            {
                _book = PersistedBook;
            }
            else
            {
                var response = await Books.GetByIdAsync(new GetBookRequest { Id = Id });
                if (response is null)
                {
                    _book = null;
                    return;
                }
                _book = response;
                PersistedBookId = Id;
                PersistedBook = response;
            }
        }
        catch
        {
            _error = "Book details could not be loaded.";
        }
        finally
        {
            _loading = false;
        }
    }
}
