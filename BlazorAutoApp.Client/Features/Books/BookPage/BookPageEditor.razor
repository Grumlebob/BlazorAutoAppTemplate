@using Microsoft.AspNetCore.Components.Forms

<section class="mx-auto w-[min(calc(100vw-2rem),42rem)]" data-testid="book-page-editor">
    <h1 class="sr-only">@Heading</h1>

    @if (_editContext is not null)
    {
        <CascadingValue Value="_editContext" IsFixed="true">
            <div class="relative overflow-hidden rounded-[2rem] border border-[#d7c3a1] bg-[#fffaf0] px-6 py-7 shadow-[0_1.25rem_2.5rem_rgb(15_23_42_/_0.14)] sm:px-10 sm:py-9">
                <DataAnnotationsValidator />
                @TopRightClose()

                <div class="pointer-events-none absolute inset-y-0 left-0 w-[4.4rem] rounded-l-[2rem] bg-[linear-gradient(90deg,#b79d75,#decbaa_45%,#f0e2ca)] sm:w-[5.1rem]" aria-hidden="true"></div>
                <div class="pointer-events-none absolute bottom-8 right-5 top-8 w-7 rounded-r-[1.5rem] border-r border-[#eadbc3] opacity-40" aria-hidden="true"></div>

                <div class="relative ml-12 sm:ml-16">
                    @if (!string.IsNullOrWhiteSpace(Error))
                    {
                        <p class="mb-4 rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">@Error</p>
                    }

                    <ValidationSummary class="mb-4 rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700" />

                    <div class="rounded-[1.5rem] border border-[#dac5a1] bg-[#fffefa] px-5 py-5 sm:px-7 sm:py-6">
                        <div class="mb-4 border-b border-[#efe1c9] pb-3">
                            <label class="mb-1 block text-sm font-semibold text-gray-700" for="@TitleInputId">Title</label>
                            <textarea id="@TitleInputId"
                                      data-testid="book-title"
                                      class="block min-h-16 w-full resize-none overflow-hidden border-0 bg-transparent px-0 py-1 font-serif text-xl font-bold leading-snug text-gray-950 outline-none placeholder:text-gray-300 focus:ring-0 sm:text-2xl lg:text-3xl"
                                      placeholder="Book title"
                                      rows="2"
                                      value="@Model.Title"
                                      @oninput="HandleTitleInput"></textarea>
                            <ValidationMessage For="() => Model.Title" class="mt-1 block text-sm text-red-600" />
                        </div>

                        <div class="mb-4">
                            <label class="mb-1 block text-sm font-semibold text-gray-700" for="@AuthorInputId">Author</label>
                            <input id="@AuthorInputId"
                                   data-testid="book-author"
                                   class="block w-full rounded-md border border-[#e7d7bd] bg-white/70 px-3 py-2 text-gray-900 shadow-sm outline-none placeholder:text-gray-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
                                   placeholder="Author"
                                   value="@Model.Author"
                                   @oninput="HandleAuthorInput" />
                            <ValidationMessage For="() => Model.Author" class="mt-1 block text-sm text-red-600" />
                        </div>

                        <div>
                            <label class="mb-1 block text-sm font-semibold text-gray-700" for="@UrlInputId">Site URL</label>
                            <input id="@UrlInputId"
                                   data-testid="book-url"
                                   type="url"
                                   class="block w-full rounded-md border border-[#e7d7bd] bg-white/70 px-3 py-2 text-gray-900 shadow-sm outline-none placeholder:text-gray-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
                                   placeholder="https://example.com/book"
                                   value="@Model.Url"
                                   @oninput="HandleUrlInput" />
                            <ValidationMessage For="() => Model.Url" class="mt-1 block text-sm text-red-600" />
                        </div>
                    </div>

                    <div class="mt-5 flex flex-wrap items-center gap-2">
                        <button data-testid="book-save"
                                class="inline-flex items-center justify-center rounded-md border border-gray-900 bg-gray-900 px-4 py-2.5 text-sm font-bold text-white shadow-sm transition-colors hover:bg-gray-950 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 disabled:cursor-not-allowed disabled:opacity-60"
                                type="button"
                                disabled="@IsBusy"
                                @onclick="SubmitAsync">
                            @SubmitLabel
                        </button>
                    </div>
                </div>
            </div>
        </CascadingValue>
    }
</section>

@code {
    private readonly string _id = Guid.NewGuid().ToString("N");
    private EditContext? _editContext;
    private BookPageEditorModel? _editContextModel;

    [Parameter, EditorRequired]
    public required BookPageEditorModel Model { get; set; }

    [Parameter, EditorRequired]
    public required EventCallback<BookPageEditorModel> OnValidSubmit { get; set; }

    [Parameter]
    public string Heading { get; set; } = "Book editor";

    [Parameter]
    public string SubmitLabel { get; set; } = "Save";

    [Parameter]
    public string CancelHref { get; set; } = "/books";

    [Parameter]
    public string CancelLabel { get; set; } = "Cancel";

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public string? Error { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    private string TitleInputId => $"book-title-{_id}";

    private string AuthorInputId => $"book-author-{_id}";

    private string UrlInputId => $"book-url-{_id}";

    private FieldIdentifier TitleField => new(Model, nameof(BookPageEditorModel.Title));

    private FieldIdentifier AuthorField => new(Model, nameof(BookPageEditorModel.Author));

    private FieldIdentifier UrlField => new(Model, nameof(BookPageEditorModel.Url));

    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(Model, _editContextModel))
        {
            _editContext = new EditContext(Model);
            _editContextModel = Model;
        }
    }

    private RenderFragment TopRightClose() => builder =>
    {
        if (OnCancel.HasDelegate)
        {
            builder.OpenElement(0, "button");
            builder.AddAttribute(1, "data-testid", "book-back");
            builder.AddAttribute(2, "class", CloseButtonClass);
            builder.AddAttribute(3, "type", "button");
            builder.AddAttribute(4, "aria-label", CancelLabel);
            builder.AddAttribute(5, "onclick", OnCancel);
            builder.AddMarkupContent(6, CloseIconMarkup);
            builder.CloseElement();
            return;
        }

        builder.OpenElement(7, "a");
        builder.AddAttribute(8, "data-testid", "book-back");
        builder.AddAttribute(9, "class", CloseButtonClass);
        builder.AddAttribute(10, "href", CancelHref);
        builder.AddAttribute(11, "target", "_top");
        builder.AddAttribute(12, "data-enhance-nav", "false");
        builder.AddAttribute(13, "aria-label", CancelLabel);
        builder.AddMarkupContent(14, CloseIconMarkup);
        builder.CloseElement();
    };

    private const string CloseButtonClass = "absolute right-5 top-5 z-10 inline-flex h-12 w-12 items-center justify-center rounded-2xl border border-[#d7c3a1] bg-[#fffefa] text-gray-700 shadow-sm transition-colors hover:bg-white hover:text-gray-950 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600";

    private const string CloseIconMarkup = """
        <svg viewBox="0 0 24 24" class="h-5 w-5" aria-hidden="true">
            <path d="M7 7l10 10M17 7L7 17" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
        </svg>
        """;

    private void HandleTitleInput(ChangeEventArgs args)
    {
        Model.Title = args.Value?.ToString() ?? string.Empty;
        _editContext?.NotifyFieldChanged(TitleField);
    }

    private void HandleAuthorInput(ChangeEventArgs args)
    {
        Model.Author = args.Value?.ToString();
        _editContext?.NotifyFieldChanged(AuthorField);
    }

    private void HandleUrlInput(ChangeEventArgs args)
    {
        Model.Url = args.Value?.ToString();
        _editContext?.NotifyFieldChanged(UrlField);
    }

    private async Task SubmitAsync()
    {
        if (_editContext?.Validate() == true)
        {
            await OnValidSubmit.InvokeAsync(Model);
        }
    }
}
