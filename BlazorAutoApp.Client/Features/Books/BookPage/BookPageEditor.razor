@using Microsoft.AspNetCore.Components.Forms

<section class="mx-auto w-[min(calc(100vw-2rem),35rem)]">
    @if (_editContext is not null)
    {
        <CascadingValue Value="_editContext" IsFixed="true">
            <DataAnnotationsValidator />
            <BookPageFrame TestId="book-page-editor"
                           Heading="@Heading"
                           Title="@Heading"
                           Description="@EditorDescription"
                           ContainerClass="mx-auto w-[min(calc(100vw-2rem),35rem)] overflow-visible">
                <TopControls>
                    <a href="@CancelHref" data-testid="book-back" aria-label="@CancelLabel">
                        <BookPageCloseControl X="430" />
                    </a>
                </TopControls>
                <MainContent>
                    <foreignObject x="108" y="132" width="344" height="252">
                        <div xmlns="http://www.w3.org/1999/xhtml"
                             class="flex h-full flex-col rounded-[28px] border border-[#dac5a1] bg-[#fffefa] px-7 py-6 text-gray-950 shadow-[inset_0_1px_0_rgb(255_255_255_/_0.75)]">
                            <label class="sr-only" for="@TitleInputId">Title</label>
                            <textarea id="@TitleInputId"
                                      data-testid="book-title"
                                      class="block min-h-0 flex-1 resize-none overflow-hidden border-0 bg-transparent px-0 pt-5 text-center font-serif text-[2rem] font-bold leading-tight text-gray-950 outline-none placeholder:text-gray-300 focus:ring-0"
                                      placeholder="Book title"
                                      rows="2"
                                      value="@Model.Title"
                                      @oninput="HandleTitleInput"></textarea>
                            <ValidationMessage For="() => Model.Title" class="mt-1 block text-center text-[0.78rem] font-semibold leading-tight text-red-700" />

                            <div class="mt-3 border-t border-[#efe1c9] pt-4">
                                <label class="sr-only" for="@AuthorInputId">Author</label>
                                <input id="@AuthorInputId"
                                       data-testid="book-author"
                                       class="block w-full border-0 bg-transparent px-1 text-center text-[1.25rem] font-medium leading-tight text-slate-600 outline-none placeholder:text-slate-300 focus:ring-0"
                                       placeholder="Author"
                                       value="@Model.Author"
                                       @oninput="HandleAuthorInput" />
                                <ValidationMessage For="() => Model.Author" class="mt-1 block text-center text-[0.78rem] font-semibold leading-tight text-red-700" />
                            </div>
                        </div>
                    </foreignObject>
                </MainContent>
                <LowerContent>
                    <foreignObject x="108" y="436" width="344" height="168">
                        <div xmlns="http://www.w3.org/1999/xhtml"
                             class="flex h-full flex-col items-center justify-end gap-3">
                            @if (!string.IsNullOrWhiteSpace(Error))
                            {
                                <p class="w-full rounded-xl border border-red-200 bg-red-50/95 px-3 py-2 text-center text-[0.82rem] font-semibold leading-snug text-red-700">@Error</p>
                            }

                            <div class="w-full rounded-2xl border border-[#eadbc3] bg-[#fffefa]/95 px-4 py-3">
                                <label class="sr-only" for="@UrlInputId">Site URL</label>
                                <input id="@UrlInputId"
                                       data-testid="book-url"
                                       type="url"
                                       class="block w-full border-0 bg-transparent text-center text-[1.05rem] font-medium text-slate-700 outline-none placeholder:text-slate-300 focus:ring-0"
                                       placeholder="https://example.com/book"
                                       value="@Model.Url"
                                       @oninput="HandleUrlInput" />
                                <ValidationMessage For="() => Model.Url" class="mt-1 block text-center text-[0.78rem] font-semibold leading-tight text-red-700" />
                            </div>

                            <button data-testid="book-save"
                                    class="inline-flex h-[3.1rem] min-w-[12.25rem] items-center justify-center rounded-full border border-slate-900 bg-slate-900 px-5 text-[1.08rem] font-bold text-white shadow-sm transition-colors hover:bg-slate-950 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 disabled:cursor-not-allowed disabled:opacity-60"
                                    type="button"
                                    disabled="@IsBusy"
                                    @onclick="SubmitAsync">
                                @SubmitLabel
                            </button>
                        </div>
                    </foreignObject>
                </LowerContent>
            </BookPageFrame>
        </CascadingValue>
    }
</section>

@code {
    private readonly string _id = Guid.NewGuid().ToString("N");
    private EditContext? _editContext;
    private BookPageEditorModel? _editContextModel;

    [Parameter, EditorRequired]
    public required BookPageEditorModel Model { get; set; }

    [Parameter, EditorRequired]
    public required EventCallback<BookPageEditorModel> OnValidSubmit { get; set; }

    [Parameter]
    public string Heading { get; set; } = "Book editor";

    [Parameter]
    public string SubmitLabel { get; set; } = "Save";

    [Parameter]
    public string CancelHref { get; set; } = "/books";

    [Parameter]
    public string CancelLabel { get; set; } = "Cancel";

    [Parameter]
    public string? Error { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    private string TitleInputId => $"book-title-{_id}";

    private string AuthorInputId => $"book-author-{_id}";

    private string UrlInputId => $"book-url-{_id}";

    private FieldIdentifier TitleField => new(Model, nameof(BookPageEditorModel.Title));

    private FieldIdentifier AuthorField => new(Model, nameof(BookPageEditorModel.Author));

    private FieldIdentifier UrlField => new(Model, nameof(BookPageEditorModel.Url));

    private string EditorDescription => $"{Heading} page with title, author, and site URL fields.";

    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(Model, _editContextModel))
        {
            _editContext = new EditContext(Model);
            _editContextModel = Model;
        }
    }

    private void HandleTitleInput(ChangeEventArgs args)
    {
        Model.Title = args.Value?.ToString() ?? string.Empty;
        _editContext?.NotifyFieldChanged(TitleField);
    }

    private void HandleAuthorInput(ChangeEventArgs args)
    {
        Model.Author = args.Value?.ToString();
        _editContext?.NotifyFieldChanged(AuthorField);
    }

    private void HandleUrlInput(ChangeEventArgs args)
    {
        Model.Url = args.Value?.ToString();
        _editContext?.NotifyFieldChanged(UrlField);
    }

    private async Task SubmitAsync()
    {
        if (_editContext?.Validate() == true)
        {
            await OnValidSubmit.InvokeAsync(Model);
        }
    }
}
