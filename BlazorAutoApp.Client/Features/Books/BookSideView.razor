<svg class="h-[8.95rem] w-[11.75rem] overflow-visible sm:h-[10.65rem] sm:w-[14rem]"
     viewBox="0 0 210 160"
     role="img"
     aria-labelledby="@TitleId">
    <title id="@TitleId">@AccessibleTitle</title>
    <defs>
        <linearGradient id="@CoverShineId" x1="18" x2="168" y1="80" y2="80" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0.22" />
            <stop offset="48%" stop-color="#ffffff" stop-opacity="0.04" />
            <stop offset="100%" stop-color="#000000" stop-opacity="0.17" />
        </linearGradient>
        <linearGradient id="@PageGradientId" x1="150" x2="196" y1="84" y2="84" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="@Colors.PageStart" />
            <stop offset="62%" stop-color="@Colors.PageMiddle" />
            <stop offset="100%" stop-color="@Colors.PageEnd" />
        </linearGradient>
    </defs>

    <ellipse cx="103" cy="145" rx="82" ry="7.5" fill="#111827" opacity="0.16" />

    @if (Variant == 0)
    {
        <g class="transition-transform duration-200 ease-out group-hover:translate-x-[3px] group-focus-visible:translate-x-[3px] motion-reduce:transform-none motion-reduce:transition-none">
            <rect x="148" y="34" width="44" height="102" rx="9" fill="url(#@PageGradientId)" />
            <path d="M155 44h28M155 56h26M155 68h29M155 80h25M155 92h29M155 104h27M155 116h28" stroke="#a8a29e" stroke-width="1.35" stroke-linecap="round" opacity="0.58" />
            <path d="M185 40v90" stroke="#8f877d" stroke-width="2" stroke-linecap="round" opacity="0.48" />
            <path d="M149 129h38c3 0 5-2 5-5v9c0 4-3 7-7 7H42c-9 0-17-3-23-9z" fill="#c8c0b5" opacity="0.86" />
        </g>
        <g class="[transform-box:fill-box] [transform-origin:12%_52%] transition-transform duration-200 ease-out group-hover:-translate-x-0.5 group-hover:-translate-y-px group-hover:-rotate-[0.8deg] group-focus-visible:-translate-x-0.5 group-focus-visible:-translate-y-px group-focus-visible:-rotate-[0.8deg] motion-reduce:transform-none motion-reduce:transition-none">
            <rect x="18" y="24" width="146" height="114" rx="10" fill="@Colors.Base" />
            <rect x="18" y="24" width="146" height="114" rx="10" fill="url(#@CoverShineId)" />
            <rect x="22" y="30" width="18" height="102" rx="7" fill="@Colors.Dark" opacity="0.48" />
            <path d="M48 35h95M48 126h95" stroke="@Colors.Line" stroke-width="2.2" stroke-linecap="round" opacity="0.68" />
            <path d="M52 44h86M52 116h86" stroke="@Colors.Accent" stroke-width="1.35" stroke-linecap="round" opacity="0.54" />
            @TitlePanel()
            @UrlMarker()
        </g>
    }
    else if (Variant == 1)
    {
        <g class="transition-transform duration-200 ease-out group-hover:translate-x-[3px] group-focus-visible:translate-x-[3px] motion-reduce:transform-none motion-reduce:transition-none">
            <rect x="150" y="34" width="46" height="102" rx="9" fill="url(#@PageGradientId)" />
            <path d="M158 45h29M158 57h27M158 69h30M158 81h26M158 93h30M158 105h28M158 117h27" stroke="#a8a29e" stroke-width="1.35" stroke-linecap="round" opacity="0.62" />
            <path d="M189 40v90" stroke="#8f877d" stroke-width="2" stroke-linecap="round" opacity="0.48" />
            <path d="M151 129h40c3 0 5-2 5-5v9c0 4-3 7-7 7H42c-9 0-17-3-23-9z" fill="#c8c0b5" opacity="0.86" />
        </g>
        <g class="[transform-box:fill-box] [transform-origin:12%_52%] transition-transform duration-200 ease-out group-hover:-translate-x-0.5 group-hover:-translate-y-px group-hover:-rotate-[0.8deg] group-focus-visible:-translate-x-0.5 group-focus-visible:-translate-y-px group-focus-visible:-rotate-[0.8deg] motion-reduce:transform-none motion-reduce:transition-none">
            <rect x="18" y="24" width="148" height="114" rx="10" fill="@Colors.Base" />
            <rect x="18" y="24" width="148" height="114" rx="10" fill="url(#@CoverShineId)" />
            <path d="M28 24h128c6 0 10 4 10 10v23H18V34c0-6 4-10 10-10z" fill="@Colors.Accent" opacity="0.9" />
            <path d="M18 118h148v10c0 6-4 10-10 10H28c-6 0-10-4-10-10z" fill="@Colors.Dark" opacity="0.32" />
            <rect x="24" y="31" width="18" height="100" rx="7" fill="@Colors.Dark" opacity="0.36" />
            <path d="M50 39h88M50 126h88" stroke="@Colors.Line" stroke-width="1.8" stroke-linecap="round" opacity="0.58" />
            @TitlePanel()
            @UrlMarker()
        </g>
    }
    else
    {
        <g class="transition-transform duration-200 ease-out group-hover:translate-x-[3px] group-focus-visible:translate-x-[3px] motion-reduce:transform-none motion-reduce:transition-none">
            <rect x="152" y="31" width="40" height="104" rx="6" fill="url(#@PageGradientId)" />
            <path d="M159 43h26M159 56h24M159 69h27M159 82h23M159 95h27M159 108h25M159 121h24" stroke="#a8a29e" stroke-width="1.25" stroke-linecap="round" opacity="0.6" />
            <path d="M187 37v92" stroke="#8f877d" stroke-width="2" stroke-linecap="round" opacity="0.48" />
            <rect x="185" y="50" width="9" height="14" rx="3" fill="@Colors.Accent" opacity="0.72" />
            <rect x="185" y="76" width="9" height="14" rx="3" fill="@Colors.Line" opacity="0.72" />
            <rect x="185" y="102" width="9" height="14" rx="3" fill="@Colors.Accent" opacity="0.58" />
            <path d="M153 129h34c3 0 5-2 5-5v9c0 4-3 7-7 7H42c-9 0-17-3-23-9z" fill="#c8c0b5" opacity="0.86" />
        </g>
        <g class="[transform-box:fill-box] [transform-origin:12%_52%] transition-transform duration-200 ease-out group-hover:-translate-x-0.5 group-hover:-translate-y-px group-hover:-rotate-[0.8deg] group-focus-visible:-translate-x-0.5 group-focus-visible:-translate-y-px group-focus-visible:-rotate-[0.8deg] motion-reduce:transform-none motion-reduce:transition-none">
            <rect x="18" y="22" width="148" height="116" rx="6" fill="@Colors.Base" />
            <rect x="18" y="22" width="148" height="116" rx="6" fill="url(#@CoverShineId)" />
            <rect x="24" y="29" width="17" height="102" rx="4" fill="@Colors.Dark" opacity="0.42" />
            <rect x="30" y="32" width="126" height="96" rx="3" fill="none" stroke="@Colors.Line" stroke-width="1.3" opacity="0.5" />
            <path d="M50 40h88M50 122h88M139 40h10M139 122h10" stroke="@Colors.Accent" stroke-width="1.5" stroke-linecap="round" opacity="0.7" />
            <path d="M34 45v70M43 45v70" stroke="@Colors.Dark" stroke-width="1.2" opacity="0.36" />
            @TitlePanel()
            @UrlMarker()
        </g>
    }
</svg>

@code {
    private readonly record struct BookPalette(
        string Base,
        string Dark,
        string Accent,
        string Line,
        string Panel,
        string PanelBorder,
        string Ink,
        string PageStart,
        string PageMiddle,
        string PageEnd);

    private static readonly BookPalette[] Palette =
    [
        new("#1f4e5f", "#082f49", "#7dd3fc", "#f8fafc", "#f8fafc", "#e0f2fe", "#111827", "#fff9ed", "#f4ead9", "#d8d0c4"),
        new("#7c2d12", "#431407", "#f59e0b", "#fed7aa", "#fff7ed", "#fed7aa", "#1c1917", "#fff9ed", "#f4ead9", "#d8d0c4"),
        new("#365314", "#1a2e05", "#14b8a6", "#bef264", "#f7fee7", "#d9f99d", "#1f2937", "#fefce8", "#eee8c9", "#d6d3d1"),
        new("#581c87", "#2e1065", "#fb7185", "#c084fc", "#faf5ff", "#f5d0fe", "#111827", "#fff7ed", "#f4ead9", "#d6d3d1"),
        new("#9f1239", "#4c0519", "#38bdf8", "#fda4af", "#fff1f2", "#fecdd3", "#111827", "#fff9ed", "#f1e7d7", "#d8d0c4"),
        new("#854d0e", "#451a03", "#22c55e", "#fcd34d", "#fffbeb", "#fde68a", "#111827", "#fefce8", "#eee8c9", "#d6d3d1"),
        new("#0f766e", "#134e4a", "#f97316", "#5eead4", "#f0fdfa", "#ccfbf1", "#111827", "#fff9ed", "#f4ead9", "#d8d0c4"),
        new("#4338ca", "#1e1b4b", "#eab308", "#a5b4fc", "#eef2ff", "#c7d2fe", "#111827", "#fefce8", "#eee8c9", "#d6d3d1"),
        new("#7f1d1d", "#450a0a", "#60a5fa", "#fca5a5", "#fef2f2", "#fecaca", "#111827", "#fff7ed", "#f4ead9", "#d8d0c4")
    ];

    private const int MaxTitleLineLength = 12;

    [Parameter]
    public int Seed { get; set; }

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Url { get; set; }

    private int StableSeed => Seed == int.MinValue ? 0 : Math.Abs(Seed);

    private int Variant => StableSeed % 3;

    private BookPalette Colors => Palette[StableSeed % Palette.Length];

    private string TitleId => $"book-side-title-{StableSeed}";

    private string CoverShineId => $"book-side-cover-shine-{StableSeed}";

    private string PageGradientId => $"book-side-pages-{StableSeed}";

    private bool HasUrl => !string.IsNullOrWhiteSpace(Url);

    private string AccessibleTitle => $"{Title}{UrlSuffix}";

    private string UrlSuffix => HasUrl ? ", includes URL" : string.Empty;

    private IReadOnlyList<string> TitleLines => SplitTitle(Title);

    private double TitleStartY => 74 - ((TitleLines.Count - 1) * 6);

    private RenderFragment TitlePanel() => @<g>
        <rect x="50" y="52" width="96" height="54" rx="8" fill="@Colors.Panel" opacity="0.98" />
        <rect x="55" y="57" width="86" height="44" rx="6" fill="#ffffff" opacity="0.2" />
        <rect x="50" y="52" width="96" height="54" rx="8" fill="none" stroke="@Colors.PanelBorder" stroke-width="1.5" opacity="0.92" />
        <svg:text x="98" y="@TitleStartY" text-anchor="middle" class="fill-[var(--book-ink)] text-[9px] font-extrabold uppercase leading-none tracking-normal sm:text-[10px]" style="@($"--book-ink: {Colors.Ink};")">
            @foreach (var line in TitleLines.Select((text, index) => new { text, index }))
            {
                <tspan x="98" dy="@(line.index == 0 ? "0" : "1.18em")">@line.text</tspan>
            }
        </svg:text>
    </g>;

    private RenderFragment UrlMarker() => @<g>
        @if (HasUrl)
        {
            <rect x="145" y="31" width="15" height="15" rx="3" fill="@Colors.Panel" opacity="0.94" />
            <path d="M149 39h7M153 35l4 4-4 4" stroke="@Colors.Ink" stroke-width="1.45" stroke-linecap="round" stroke-linejoin="round" />
        }
    </g>;

    private static IReadOnlyList<string> SplitTitle(string title)
    {
        var clean = string.IsNullOrWhiteSpace(title) ? "Untitled" : title.Trim();
        var words = clean.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var lines = new List<string>();
        var current = string.Empty;

        foreach (var word in words)
        {
            var candidate = current.Length == 0 ? word : $"{current} {word}";
            if (candidate.Length <= MaxTitleLineLength)
            {
                current = candidate;
                continue;
            }

            if (current.Length > 0)
            {
                lines.Add(TrimLine(current, MaxTitleLineLength));
            }

            current = word;
            if (lines.Count == 2)
            {
                break;
            }
        }

        if (current.Length > 0 && lines.Count < 3)
        {
            lines.Add(TrimLine(current, MaxTitleLineLength));
        }

        return lines.Count == 0 ? ["Untitled"] : lines;
    }

    private static string TrimLine(string value, int maxLength) =>
        value.Length <= maxLength ? value : value[..(maxLength - 1)] + ".";
}
