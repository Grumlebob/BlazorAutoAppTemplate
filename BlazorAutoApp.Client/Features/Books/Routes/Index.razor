@page "/"
@page "/books"

@* Canonical Books route. Compatibility route components in this slice redirect old URLs into the query-modal flow. *@

<PageTitle>Books</PageTitle>

<div class="mx-auto max-w-6xl">
    <div class="mb-4">
        <div>
            <h1 class="mb-1 text-3xl font-bold leading-tight tracking-normal text-gray-900">Books</h1>
            <p class="text-[0.95rem] text-gray-600">A template for quickly deploying Blazor Auto production-ready systems.</p>
        </div>
    </div>

    <AuthorBookcase />

    <div class="mt-3">
        <RenderModeBadge Assigned="@AssignedRenderMode" ConfiguredMode="Interactive Auto" />
    </div>

    <AuthorizeView>
        <Authorized>
            <UserBookcase />
        </Authorized>
        <NotAuthorized>
            <UserBookcaseLoginPrompt />
        </NotAuthorized>
        <Authorizing>
            <p class="mt-6 text-gray-600">Checking your bookcase...</p>
        </Authorizing>
    </AuthorizeView>

    <BookModalHost />
</div>
