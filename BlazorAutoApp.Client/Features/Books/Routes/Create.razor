@page "/books/create"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@inject NavigationManager Nav

<PageTitle>Add Book</PageTitle>

<h1 class="sr-only">Opening add book</h1>

@* Compatibility route: the actual add flow is the modal on /books. *@

@code {
    protected override void OnInitialized() =>
        Nav.NavigateTo("/books?bookMode=create", forceLoad: false, replace: true);
}
