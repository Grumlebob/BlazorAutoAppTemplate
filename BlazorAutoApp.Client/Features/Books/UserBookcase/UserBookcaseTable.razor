<section class="mt-6" aria-label="Your saved books">
    <div class="flex items-baseline justify-between gap-4 border-b border-gray-200 pb-2">
        <h2 class="mb-0 text-xl font-semibold text-gray-800">Saved books</h2>
        <span class="text-sm text-gray-500">@Books.Count total</span>
    </div>

    <div class="mt-3 grid gap-3">
        @foreach (var book in Books)
        {
            <article class="grid items-center gap-3 border-b border-gray-100 py-3 md:grid-cols-[minmax(0,1fr)_auto]" data-testid="@($"book-row-{book.Id}")">
                <div>
                    <h3 class="mb-0.5 text-base font-semibold leading-snug text-gray-900">@book.Title</h3>
                    <p class="text-sm text-gray-600">@(string.IsNullOrWhiteSpace(book.Author) ? "Unknown author" : book.Author)</p>
                    @if (string.IsNullOrWhiteSpace(book.Url))
                    {
                        <span class="mt-1 inline-block text-[0.8rem] text-gray-500">No site</span>
                    }
                    else
                    {
                        <a class="mt-1 inline-flex text-[0.8rem] font-bold text-blue-700 no-underline hover:text-blue-800 hover:underline"
                           href="@book.Url"
                           target="_blank"
                           rel="noopener noreferrer">Go to site</a>
                    }
                </div>
                <div class="flex flex-wrap gap-2">
                    <a data-testid="book-view" class="inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-2.5 py-2 text-[0.8rem] font-bold text-gray-700 no-underline hover:bg-gray-50 hover:text-gray-900" href="@($"/books?bookSource=user&bookId={book.Id.ToString(System.Globalization.CultureInfo.InvariantCulture)}&bookMode=view")">View</a>
                    <a data-testid="book-edit" class="inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-2.5 py-2 text-[0.8rem] font-bold text-gray-700 no-underline hover:bg-gray-50 hover:text-gray-900" href="@($"/books?bookSource=user&bookId={book.Id.ToString(System.Globalization.CultureInfo.InvariantCulture)}&bookMode=edit")">Edit</a>
                    <button data-testid="book-delete" class="inline-flex items-center justify-center rounded-md border border-red-200 bg-white px-2.5 py-2 text-[0.8rem] font-bold text-red-700 hover:bg-red-50 hover:text-red-800" type="button" @onclick="() => OnDelete.InvokeAsync(book.Id)">Delete</button>
                </div>
            </article>
        }
    </div>
</section>

@code {
    [Parameter, EditorRequired]
    public required IReadOnlyList<Book> Books { get; set; }

    [Parameter, EditorRequired]
    public required EventCallback<int> OnDelete { get; set; }
}
