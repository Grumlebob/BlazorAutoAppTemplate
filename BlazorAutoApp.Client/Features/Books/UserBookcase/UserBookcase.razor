@implements IDisposable

@inject UserBookcaseState UserBooks
@inject IJSRuntime JS

@if (UserBooks.IsLoading)
{
    <p class="mt-6 text-gray-600">Loading your bookcase...</p>
}
else if (UserBooks.Error is not null)
{
    <p class="mt-6 text-red-600">@UserBooks.Error</p>
}
else
{
    var hasUserBooks = UserBooks.Books.Count > 0;

    <BookcaseShelf Title="Your Bookcase"
                   Description="Only books you have saved."
                   TestId="user-bookcase"
                   Books="UserBookcaseBookMapper.ToBookcaseBooks(UserBooks.Books)"
                   LinkBooks="true"
                   EmptyMessage="Your bookcase is empty."
                   EmptyTestId="user-book-empty-state">
        <Actions>
            <a data-testid="add-book"
               class="inline-flex items-center justify-center rounded-md border border-gray-800 bg-gray-800 px-3.5 py-2.5 text-sm font-bold leading-5 text-white no-underline transition-colors hover:bg-gray-950 hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600"
               href="/books?bookMode=create">Add Book</a>
        </Actions>
    </BookcaseShelf>

    @if (hasUserBooks)
    {
        <UserBookcaseTable Books="UserBooks.Books" OnDelete="DeleteAsync" />
    }
}

@code {
    protected override async Task OnInitializedAsync()
    {
        UserBooks.Changed += HandleBooksChanged;
        await UserBooks.LoadForCurrentUserAsync(forceRefresh: true);
    }

    private async Task DeleteAsync(int id)
    {
        try
        {
            var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this book?");
            if (!confirmed)
            {
                return;
            }

            await UserBooks.DeleteAsync(id);
        }
        catch
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private void HandleBooksChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose() => UserBooks.Changed -= HandleBooksChanged;
}
