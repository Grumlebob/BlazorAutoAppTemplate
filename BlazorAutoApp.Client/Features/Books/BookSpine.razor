<svg class="book-spine-svg" viewBox="0 0 72 132" role="img" aria-labelledby="@TitleId">
    <title id="@TitleId">@AccessibleTitle</title>
    <defs>
        <linearGradient id="@ShineId" x1="0" x2="1" y1="0" y2="0">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0.22" />
            <stop offset="42%" stop-color="#ffffff" stop-opacity="0.04" />
            <stop offset="100%" stop-color="#000000" stop-opacity="0.18" />
        </linearGradient>
    </defs>

    <rect x="5" y="3" width="62" height="126" rx="5" fill="@Colors.Base" />
    <rect x="5" y="3" width="62" height="126" rx="5" fill="url(#@ShineId)" />
    <rect x="7" y="6" width="7" height="120" rx="3" fill="@Colors.Light" opacity="0.44" />
    <rect x="58" y="6" width="7" height="120" rx="3" fill="@Colors.Dark" opacity="0.45" />

    @if (Variant == 0)
    {
        <rect x="18" y="11" width="36" height="7" rx="2" fill="@Colors.Light" opacity="0.72" />
        <rect x="18" y="114" width="36" height="7" rx="2" fill="@Colors.Light" opacity="0.72" />
        <rect x="18" y="25" width="36" height="7" rx="2" fill="@Colors.Dark" opacity="0.28" />
        <rect x="18" y="100" width="36" height="7" rx="2" fill="@Colors.Dark" opacity="0.28" />
        <rect x="16" y="39" width="40" height="46" rx="4" fill="#f8fafc" opacity="0.92" />
        <rect x="20" y="43" width="32" height="38" rx="2" fill="@Colors.Accent" opacity="0.18" />
        <path d="M18 39h36M18 85h36" stroke="@Colors.Metal" stroke-width="1.2" opacity="0.85" />
        <svg:text x="36" y="48" text-anchor="middle" class="book-spine-title book-spine-title-on-label" fill="@Colors.Ink">
            @foreach (var line in TitleLines)
            {
                <tspan x="36" dy="1.05em">@line</tspan>
            }
        </svg:text>
        <svg:text x="36" y="91" text-anchor="middle" class="book-spine-author" fill="@Colors.Text">@AuthorLabel</svg:text>
    }
    else if (Variant == 1)
    {
        <rect x="14" y="9" width="44" height="20" rx="3" fill="@Colors.Accent" opacity="0.9" />
        <path d="M14 35h44v15H14zM14 92h44v16H14z" fill="@Colors.Dark" opacity="0.42" />
        <path d="M14 58l44-18v13L14 71z" fill="@Colors.Light" opacity="0.5" />
        <circle cx="36" cy="116" r="5" fill="@Colors.Accent" opacity="0.92" />
        <circle cx="36" cy="116" r="2.5" fill="@Colors.Light" opacity="0.9" />
        <svg:text x="36" y="39" text-anchor="middle" class="book-spine-title" fill="@Colors.Text">
            @foreach (var line in TitleLines)
            {
                <tspan x="36" dy="1.05em">@line</tspan>
            }
        </svg:text>
        <svg:text x="36" y="88" text-anchor="middle" class="book-spine-author" fill="@Colors.Text">@AuthorLabel</svg:text>
    }
    else
    {
        <rect x="16" y="12" width="40" height="108" rx="4" fill="@Colors.Dark" opacity="0.36" />
        <path d="M20 18h32M20 114h32M20 31h32M20 101h32" stroke="@Colors.Metal" stroke-width="1.6" opacity="0.95" />
        <path d="M23 24c3-4 23-4 26 0M23 108c3 4 23 4 26 0" stroke="@Colors.Metal" stroke-width="1" fill="none" opacity="0.85" />
        <rect x="19" y="43" width="34" height="42" rx="14" fill="@Colors.Base" stroke="@Colors.Metal" stroke-width="1.4" />
        <path d="M25 49h22M25 79h22" stroke="@Colors.Metal" stroke-width="1" opacity="0.85" />
        <circle cx="20" cy="18" r="2" fill="@Colors.Metal" opacity="0.9" />
        <circle cx="52" cy="18" r="2" fill="@Colors.Metal" opacity="0.9" />
        <circle cx="20" cy="114" r="2" fill="@Colors.Metal" opacity="0.9" />
        <circle cx="52" cy="114" r="2" fill="@Colors.Metal" opacity="0.9" />
        <svg:text x="36" y="51" text-anchor="middle" class="book-spine-title" fill="@Colors.Text">
            @foreach (var line in TitleLines)
            {
                <tspan x="36" dy="1.05em">@line</tspan>
            }
        </svg:text>
        <svg:text x="36" y="93" text-anchor="middle" class="book-spine-author" fill="@Colors.Metal">@AuthorLabel</svg:text>
    }

    @if (HasUrl)
    {
        <g aria-hidden="true">
            <rect x="47" y="10" width="11" height="11" rx="2" fill="@Colors.Metal" opacity="0.95" />
            <path d="M50 16h5M53 13l3 3-3 3" stroke="@Colors.Ink" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
        </g>
    }
</svg>

@code {
    private readonly record struct SpinePalette(
        string Base,
        string Dark,
        string Light,
        string Accent,
        string Text,
        string Ink,
        string Metal);

    private static readonly SpinePalette[] Palette =
    [
        new("#1f4e5f", "#082f49", "#7dd3fc", "#f59e0b", "#ffffff", "#111827", "#f8fafc"),
        new("#7c2d12", "#431407", "#fdba74", "#facc15", "#fff7ed", "#1c1917", "#fde68a"),
        new("#365314", "#1a2e05", "#bef264", "#14b8a6", "#f7fee7", "#1f2937", "#d9f99d"),
        new("#581c87", "#2e1065", "#c084fc", "#fb7185", "#faf5ff", "#111827", "#f5d0fe"),
        new("#9f1239", "#4c0519", "#fda4af", "#38bdf8", "#fff1f2", "#111827", "#fecdd3"),
        new("#854d0e", "#451a03", "#fcd34d", "#22c55e", "#fffbeb", "#111827", "#fde68a"),
        new("#0f766e", "#134e4a", "#5eead4", "#f97316", "#f0fdfa", "#111827", "#ccfbf1"),
        new("#4338ca", "#1e1b4b", "#a5b4fc", "#eab308", "#eef2ff", "#111827", "#c7d2fe"),
        new("#7f1d1d", "#450a0a", "#fca5a5", "#60a5fa", "#fef2f2", "#111827", "#fecaca"),
        new("#14532d", "#052e16", "#86efac", "#f59e0b", "#f0fdf4", "#111827", "#bbf7d0")
    ];

    [Parameter]
    public int Seed { get; set; }

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Author { get; set; }

    [Parameter]
    public string? Url { get; set; }

    private int StableSeed => Seed == int.MinValue ? 0 : Math.Abs(Seed);

    private int Variant => StableSeed % 3;

    private SpinePalette Colors => Palette[StableSeed % Palette.Length];

    private string TitleId => $"book-spine-title-{StableSeed}";

    private string ShineId => $"book-spine-shine-{StableSeed}";

    private bool HasUrl => !string.IsNullOrWhiteSpace(Url);

    private string AccessibleTitle =>
        string.IsNullOrWhiteSpace(Author)
            ? $"{Title}{UrlSuffix}"
            : $"{Title} by {Author}{UrlSuffix}";

    private string UrlSuffix => HasUrl ? ", includes URL" : string.Empty;

    private string AuthorLabel => TrimLine(string.IsNullOrWhiteSpace(Author) ? "Unknown" : Author);

    private IReadOnlyList<string> TitleLines => SplitTitle(Title);

    private static IReadOnlyList<string> SplitTitle(string title)
    {
        var clean = string.IsNullOrWhiteSpace(title) ? "Untitled" : title.Trim();
        var words = clean.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var lines = new List<string>();
        var current = string.Empty;

        foreach (var word in words)
        {
            var candidate = current.Length == 0 ? word : $"{current} {word}";
            if (candidate.Length <= 10)
            {
                current = candidate;
                continue;
            }

            if (current.Length > 0)
            {
                lines.Add(TrimLine(current));
            }

            current = word;
            if (lines.Count == 3)
            {
                break;
            }
        }

        if (current.Length > 0 && lines.Count < 4)
        {
            lines.Add(TrimLine(current));
        }

        return lines.Count == 0 ? ["Untitled"] : lines;
    }

    private static string TrimLine(string value) =>
        value.Length <= 12 ? value : value[..11] + ".";
}
