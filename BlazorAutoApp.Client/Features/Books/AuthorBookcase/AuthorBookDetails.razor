@page "/books/author/{Slug}"

@inject NavigationManager Nav

<PageTitle>Books</PageTitle>

<h1 class="sr-only">Opening book</h1>

@code {
    [Parameter]
    public string? Slug { get; set; }

    protected override void OnParametersSet()
    {
        var page = AuthorBookcaseCatalog.FindBySlug(Slug);
        var authorBookId = (page?.Id ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture);
        Nav.NavigateTo($"/books?authorBookId={authorBookId}&bookMode=view", forceLoad: false, replace: true);
    }
}
