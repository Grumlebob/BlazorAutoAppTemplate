<BookCoverRenderer Design="@_renderModel.Design"
                   Theme="@_renderModel.Theme"
                   TitleLines="@_renderModel.TitleLines"
                   TitleY="@_renderModel.TitleY"
                   TitleFontSize="@_renderModel.TitleFontSize"
                   AccessibleTitle="@_renderModel.DisplayTitle"
                   SvgClass="h-[19.7rem] w-[17.25rem] overflow-visible sm:h-[23.625rem] sm:w-[20.65rem]"
                   ForcedOpen="@ForcedOpen" />

@code {
    private BookSideViewRenderModel _renderModel = BuildRenderModel(0, string.Empty);

    [Parameter]
    public int Seed { get; set; }

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Url { get; set; }

    [Parameter]
    public bool ForcedOpen { get; set; }

    protected override void OnParametersSet()
    {
        _renderModel = BuildRenderModel(Seed, Title);
    }

    private static readonly BookCoverTheme[] Themes =
    [
        new("#2f6f82", "#1f4e5f", "#123342", "#f8fafc", "#e0f2fe", "#111827", "#fff9ed", "#f1e3cf", "#d6c8b8", "#a99f91", "#e0f2fe"),
        new("#f59e0b", "#9a3412", "#431407", "#fff7ed", "#fed7aa", "#1c1917", "#fff7ed", "#f0dfc7", "#d7cabc", "#a99f91", "#fed7aa"),
        new("#4d7c0f", "#365314", "#1a2e05", "#f7fee7", "#d9f99d", "#1f2937", "#fefce8", "#eee8c9", "#d6d3d1", "#9b958c", "#d9f99d"),
        new("#4338ca", "#581c87", "#2e1065", "#eef2ff", "#c7d2fe", "#111827", "#fff7ed", "#f1e7d7", "#d6d3d1", "#a99f91", "#c7d2fe"),
        new("#be123c", "#9f1239", "#4c0519", "#fff1f2", "#fecdd3", "#111827", "#fefce8", "#eee8c9", "#cfc7b8", "#9b958c", "#fecdd3"),
        new("#0f766e", "#0f766e", "#134e4a", "#f0fdfa", "#ccfbf1", "#111827", "#fff9ed", "#f4ead9", "#d8d0c4", "#a8a29e", "#ccfbf1")
    ];

    private static BookSideViewRenderModel BuildRenderModel(int seed, string title)
    {
        var displayTitle = string.IsNullOrWhiteSpace(title) ? "Untitled" : title.Trim();
        var stableSeed = unchecked((uint)seed);
        var stableTitleSeed = ComputeStableTitleSeed(displayTitle);
        var design = BookCoverDesignCatalog.All[(int)(MixDesignSeed(unchecked(stableTitleSeed + stableSeed)) % (uint)BookCoverDesignCatalog.All.Count)];
        var theme = Themes[(int)(stableSeed % (uint)Themes.Length)];
        var titleLines = BookCoverTextLayout.TitleLines(displayTitle);
        var titleY = titleLines.Count switch
        {
            1 => design.Kind is BookCoverDesignKind.ClothHardback ? 111 : 114,
            2 => design.Kind is BookCoverDesignKind.ClothHardback ? 98 : 103,
            _ => 94
        };
        var titleFontSize = titleLines.Count >= 3 ? "10.5" : "11.5";

        return new BookSideViewRenderModel(
            displayTitle,
            design,
            theme,
            titleLines,
            titleY,
            titleFontSize);
    }

    private static uint ComputeStableTitleSeed(string value)
    {
        unchecked
        {
            var hash = 2166136261u;
            foreach (var character in value.AsSpan().Trim())
            {
                hash ^= character;
                hash *= 16777619u;
            }

            return hash;
        }
    }

    private static uint MixDesignSeed(uint value)
    {
        unchecked
        {
            value ^= value >> 16;
            value *= 2246822519u;
            value ^= value >> 13;
            value *= 3266489917u;
            value ^= value >> 16;
            return value;
        }
    }

    private sealed record BookSideViewRenderModel(
        string DisplayTitle,
        BookCoverDesignDefinition Design,
        BookCoverTheme Theme,
        IReadOnlyList<string> TitleLines,
        int TitleY,
        string TitleFontSize);
}
