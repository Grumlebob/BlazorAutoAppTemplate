@if (Kind is BookCoverDesignKind.FieldNotebook)
{
    <g>
        <rect x="154" y="48" width="7" height="14" rx="2.5" fill="#f97316" opacity="0.62" />
        <rect x="154" y="78" width="7" height="14" rx="2.5" fill="#fde047" opacity="0.62" />
        <rect x="154" y="108" width="7" height="14" rx="2.5" fill="#5eead4" opacity="0.62" />
        <rect x="154" y="138" width="7" height="14" rx="2.5" fill="#38bdf8" opacity="0.58" />
    </g>
}
else if (Kind is BookCoverDesignKind.DropletMonograph)
{
    <g>
        <rect x="154" y="62" width="7" height="17" rx="2.5" fill="#bae6fd" opacity="0.62" />
        <rect x="154" y="99" width="7" height="17" rx="2.5" fill="#67e8f9" opacity="0.54" />
        <rect x="154" y="136" width="7" height="17" rx="2.5" fill="#e0f2fe" opacity="0.58" />
    </g>
}
else if (Kind is BookCoverDesignKind.CompassFieldbook)
{
    <g>
        <rect x="154" y="54" width="7" height="16" rx="2.5" fill="#fbbf24" opacity="0.62" />
        <rect x="154" y="88" width="7" height="16" rx="2.5" fill="#cbd5e1" opacity="0.56" />
        <rect x="154" y="122" width="7" height="16" rx="2.5" fill="#f8fafc" opacity="0.5" />
        <rect x="154" y="156" width="7" height="16" rx="2.5" fill="#fbbf24" opacity="0.5" />
    </g>
}

@code {
    [Parameter, EditorRequired]
    public BookCoverDesignKind Kind { get; set; }
}
