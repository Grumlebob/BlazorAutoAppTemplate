<section class="@SectionClass" aria-label="@Title" data-testid="@TestId">
    <div class="mb-2 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
            <h2 class="mb-0 text-xl font-semibold leading-snug text-gray-900" data-testid="@($"{TestId}-title")">@Title</h2>
            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <p class="mt-1 text-sm text-gray-600">@Description</p>
            }
        </div>
        @if (Actions is not null)
        {
            <div class="flex flex-wrap gap-2">
                @Actions
            </div>
        }
    </div>

    @if (Books.Count == 0)
    {
        <div class="border-y border-gray-200 bg-white px-3 py-8 text-center text-sm text-gray-600" data-testid="@EmptyTestId">
            @EmptyMessage
        </div>
    }
    else
    {
        var shelfItems = BuildShelfItems();
        var useAutoScroll = AutoScroll && shelfItems.Count > 1;
        var viewportClass = useAutoScroll ? $"{ShelfViewportClass} bookcase-auto-scroll" : ShelfViewportClass;
        var trackClass = useAutoScroll ? $"{ShelfTrackClass} bookcase-track-auto" : ShelfTrackClass;

        <div class="overflow-hidden">
            <div class="@viewportClass"
                 tabindex="0"
                 aria-label="@($"{Title} scrollable shelf")">
                <div class="@trackClass">
                    @for (var index = 0; index < shelfItems.Count; index++)
                    {
                        var book = shelfItems[index];
                        var seed = BuildBookSeed(book, index);

                        if (LinkBooks && !string.IsNullOrWhiteSpace(book.Href))
                        {
                            <a data-testid="@($"{TestId}-book")"
                               @key="BuildBookKey(book, index)"
                               class="@BookFrameClass"
                               href="@book.Href"
                               aria-label="@($"{book.Title} details")">
                                <BookSideView Seed="@seed" Title="@book.Title" Url="@book.Url" />
                            </a>
                        }
                        else
                        {
                            <span data-testid="@($"{TestId}-book")"
                                  @key="BuildBookKey(book, index)"
                                  class="@BookFrameClass">
                                <BookSideView Seed="@seed" Title="@book.Title" Url="@book.Url" />
                            </span>
                        }
                    }
                </div>
            </div>
            <div class="h-[1.35rem] bg-[linear-gradient(180deg,#6b4f35_0%,#49331f_72%,#2f2116_100%)] shadow-[inset_0_1px_0_rgb(255_255_255_/_0.22),0_0.5rem_1.25rem_rgb(17_24_39_/_0.12)] sm:h-[1.65rem]" aria-hidden="true"></div>
        </div>
    }
</section>

@code {
    private const string BookFrameClass = "group block flex-none origin-bottom text-inherit no-underline [content-visibility:auto] [contain-intrinsic-size:17.25rem_19.7rem] transition-[transform,filter] duration-200 ease-out hover:-translate-y-1 hover:drop-shadow-[0_0.8rem_0.7rem_rgb(17_24_39_/_0.18)] focus-visible:-translate-y-1 focus-visible:drop-shadow-[0_0.8rem_0.7rem_rgb(17_24_39_/_0.18)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-600 motion-reduce:transition-none sm:[contain-intrinsic-size:20.65rem_23.625rem]";
    private const string ShelfViewportClass = "group/bookcase overflow-x-hidden overflow-y-hidden overscroll-x-contain border-y border-t-gray-200 border-b-gray-300 bg-[linear-gradient(180deg,rgb(255_255_255_/_0.88),rgb(249_250_251_/_0.98)),repeating-linear-gradient(90deg,#f3f4f6_0_72px,#ffffff_72px_144px)] px-3 pt-8 [scrollbar-width:none] [-ms-overflow-style:none] hover:overflow-x-auto focus:overflow-x-auto focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 focus-within:overflow-x-auto sm:pt-10 [&::-webkit-scrollbar]:hidden";
    private IReadOnlyList<BookcaseBook>? _cachedBooksSource;
    private IReadOnlyList<BookcaseBook> _cachedShelfItems = [];
    private bool _cachedLimitItems;
    private int _cachedMaxItems;

    [Parameter, EditorRequired]
    public required string Title { get; set; }

    [Parameter]
    public string? Description { get; set; }

    [Parameter, EditorRequired]
    public required string TestId { get; set; }

    [Parameter]
    public IReadOnlyList<BookcaseBook> Books { get; set; } = [];

    [Parameter]
    public bool LinkBooks { get; set; }

    [Parameter]
    public bool LimitItems { get; set; } = true;

    [Parameter]
    public int MaxItems { get; set; } = BookcaseShelfItems.DefaultMaxItems;

    [Parameter]
    public bool AutoScroll { get; set; }

    [Parameter]
    public string EmptyMessage { get; set; } = "No books saved yet.";

    [Parameter]
    public string EmptyTestId { get; set; } = "bookcase-empty-state";

    [Parameter]
    public string SectionClass { get; set; } = "mt-6";

    [Parameter]
    public RenderFragment? Actions { get; set; }

    private const string ShelfTrackClass = "flex w-max gap-[1.5rem] sm:gap-[1.9rem]";

    private IReadOnlyList<BookcaseBook> BuildShelfItems()
    {
        if (Books.Count == 0)
        {
            _cachedBooksSource = Books;
            _cachedShelfItems = [];
            return [];
        }

        var maxItems = BookcaseShelfItems.NormalizeItemCount(MaxItems);

        if (ReferenceEquals(_cachedBooksSource, Books) &&
            _cachedLimitItems == LimitItems &&
            _cachedMaxItems == maxItems)
        {
            return _cachedShelfItems;
        }

        var items = BookcaseShelfItems.Build(Books, LimitItems, maxItems);

        _cachedBooksSource = Books;
        _cachedLimitItems = LimitItems;
        _cachedMaxItems = maxItems;
        _cachedShelfItems = items;
        return _cachedShelfItems;
    }

    private int BuildBookSeed(BookcaseBook book, int index)
    {
        unchecked
        {
            var hash = 2166136261u;
            hash = AddHash(hash, TestId);
            hash = AddHash(hash, book.Id);
            hash = AddHash(hash, book.Title);
            hash = AddHash(hash, index);
            return (int)hash;
        }
    }

    private static string BuildBookKey(BookcaseBook book, int index) =>
        string.Join(':',
            index.ToString(System.Globalization.CultureInfo.InvariantCulture),
            book.Id.ToString(System.Globalization.CultureInfo.InvariantCulture),
            book.Title);

    private static uint AddHash(uint hash, int value)
    {
        unchecked
        {
            hash ^= (uint)value;
            return hash * 16777619u;
        }
    }

    private static uint AddHash(uint hash, string? value)
    {
        unchecked
        {
            foreach (var character in value.AsSpan())
            {
                hash ^= character;
                hash *= 16777619u;
            }

            return hash;
        }
    }
}
