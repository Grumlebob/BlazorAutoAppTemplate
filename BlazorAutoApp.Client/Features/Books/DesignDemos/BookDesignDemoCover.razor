<BookCoverRenderer Design="@Design.Definition"
                   Theme="@Theme"
                   TitleLines="@Design.TitleLines"
                   TitleY="@Design.TitleY"
                   TitleFontSize="@Design.TitleFontSize"
                   TitleDy="@Design.TitleDy"
                   AccessibleTitle="@Design.Label"
                   SvgClass="@SvgClass"
                   ForcedOpen="@ForcedOpen" />

@code {
    [Parameter, EditorRequired]
    public required BookDesignDemo Design { get; set; }

    [Parameter]
    public bool ForcedOpen { get; set; }

    [Parameter]
    public string SvgClass { get; set; } = "h-auto w-full";

    private BookCoverTheme Theme => new(
        Design.CoverColors.Start,
        Design.CoverColors.Middle,
        Design.CoverColors.End,
        Design.Plate.Fill,
        Design.Plate.Stroke,
        Design.TitleFill,
        Design.PageColors.Start,
        Design.PageColors.Middle,
        Design.PageColors.End,
        Design.LineStroke,
        Design.Plate.Stroke);
}
