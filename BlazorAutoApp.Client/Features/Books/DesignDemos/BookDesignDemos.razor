@page "/books/design-demos"

<PageTitle>Book Design Demos</PageTitle>

<div class="mx-0 w-[min(100%,20.5rem)] max-w-6xl overflow-hidden sm:mx-auto sm:w-full sm:px-6 lg:px-0">
    <div class="mb-6 flex flex-col gap-2">
        <a class="w-fit text-sm font-bold text-blue-700 no-underline hover:underline focus-visible:underline" href="/books">Back to books</a>
        <h1 class="mb-0 text-3xl font-bold leading-tight text-gray-950">Book Design Demos</h1>
        <p class="max-w-3xl text-[0.95rem] leading-6 text-gray-600">
            A live catalog of the SVG book covers used by the bookcase. Open a design to inspect its normal and opening states at a larger size.
        </p>
    </div>

    <div class="grid min-w-0 gap-4 sm:grid-cols-2 xl:grid-cols-3">
        @foreach (var design in BookDesignDemoCatalog.All)
        {
            <article class="min-w-0 max-w-full overflow-hidden rounded-lg border border-gray-200 bg-white p-4 shadow-[0_0.6rem_1.5rem_rgb(15_23_42_/_0.06)] [content-visibility:auto] [contain-intrinsic-size:21rem_34rem] sm:[contain-intrinsic-size:24rem_38rem]">
                <div class="mb-3 flex items-baseline justify-between gap-3">
                    <h2 class="mb-0 min-w-0 text-base font-bold leading-snug text-gray-950">@design.Label</h2>
                    <span class="text-xs font-bold text-gray-500">@((BookDesignDemoCatalog.IndexOf(design) + 1).ToString("00", System.Globalization.CultureInfo.InvariantCulture))</span>
                </div>

                <a class="group block max-w-full overflow-hidden rounded-md border border-gray-200 bg-[linear-gradient(180deg,rgb(255_255_255_/_0.92),rgb(248_250_252_/_0.98)),repeating-linear-gradient(90deg,#f1f5f9_0_72px,#ffffff_72px_144px)] px-3 py-8 no-underline transition-shadow hover:shadow-[0_1rem_2rem_rgb(15_23_42_/_0.08)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 sm:px-8 sm:py-10"
                   href="@BookDesignDemoCatalog.DetailsUrl(design)"
                   aria-label="@($"Open full-page demo for {design.Label}")">
                    <BookDesignDemoCover Design="design" SvgClass="mx-auto h-auto w-full max-w-[13rem] sm:max-w-[16rem]" />
                </a>

                <p class="mt-3 text-sm leading-5 text-gray-600">@design.Note</p>
                <div class="mt-3 flex flex-wrap gap-3">
                    <a class="text-sm font-bold text-blue-700 no-underline hover:underline focus-visible:underline" href="@BookDesignDemoCatalog.DetailsUrl(design)">Open full-page demo</a>
                    <a class="text-sm font-bold text-blue-700 no-underline hover:underline focus-visible:underline" href="@BookDesignDemoCatalog.DetailsUrl(design, forcedOpen: true)">Open forced state</a>
                </div>
            </article>
        }
    </div>
</div>
