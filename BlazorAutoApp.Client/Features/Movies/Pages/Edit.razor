@page "/movies/edit/{Id:int}"

@inject IMoviesApi Movies
@inject NavigationManager Nav

<h1 class="text-2xl font-semibold mb-2">Edit Movie</h1>

@if (_loading)
{
    <p>Loading...</p>
}
else if (_error is not null)
{
    <p class="text-red-600">@_error</p>
}
else
{
    <EditForm Model="_model" OnValidSubmit="HandleSubmit" class="max-w-xl">
        <DataAnnotationsValidator />
        <ValidationSummary class="mb-3 text-sm text-red-600" />
        <div class="mb-3">
            <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
            <InputText data-testid="movie-title" class="block w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-blue-500 focus:ring-blue-500" @bind-Value="_model.Title" />
            <ValidationMessage For="() => _model.Title" class="text-sm text-red-600" />
        </div>
        <div class="mb-3">
            <label class="block text-sm font-medium text-gray-700 mb-1">Director</label>
            <InputText data-testid="movie-director" class="block w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-blue-500 focus:ring-blue-500" @bind-Value="_model.Director" />
            <ValidationMessage For="() => _model.Director" class="text-sm text-red-600" />
        </div>
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Rating</label>
            <InputNumber data-testid="movie-rating" class="block w-32 rounded-md border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-blue-500 focus:ring-blue-500" @bind-Value="_model.Rating" />
            <ValidationMessage For="() => _model.Rating" class="text-sm text-red-600" />
        </div>
        <div class="flex items-center gap-2">
            <button data-testid="movie-save" class="inline-flex items-center rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white shadow-sm hover:bg-blue-700" type="submit">Save</button>
            <a data-testid="movie-cancel" class="inline-flex items-center rounded-md border border-gray-400 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" href="/movies">Cancel</a>
        </div>
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }

    private bool _loading = true;
    private string? _error;
    private UpdateMovieRequest _model = new() { Id = 0, Title = string.Empty, Rating = 0 };

    [PersistentState]
    public int? PersistedMovieId { get; set; }

    [PersistentState]
    public GetMovieResponse? PersistedMovie { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            if (PersistedMovieId == Id && PersistedMovie is not null)
            {
                ApplyMovie(PersistedMovie);
            }
            else
            {
                var response = await Movies.GetByIdAsync(new GetMovieRequest { Id = Id });
                if (response is null)
                {
                    _error = "Movie not found";
                    return;
                }

                PersistedMovieId = Id;
                PersistedMovie = response;
                ApplyMovie(response);
            }
        }
        catch
        {
            _error = "Movie could not be loaded.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleSubmit()
    {
        try
        {
            var success = await Movies.UpdateAsync(_model);
            if (success) Nav.NavigateTo("/movies");
        }
        catch
        {
            _error = "Movie could not be saved.";
        }
    }

    private void ApplyMovie(GetMovieResponse movie)
    {
        _model = new UpdateMovieRequest
        {
            Id = movie.Id,
            Title = movie.Title,
            Director = movie.Director,
            Rating = movie.Rating
        };
    }
}
