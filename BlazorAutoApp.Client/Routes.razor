@using BlazorAutoApp.Client.Features.AppShell.Layout
@using BlazorAutoApp.Client.Features.AppShell.Routes
@using BlazorAutoApp.Client.Features.Login.Components

<Router AppAssembly="typeof(Program).Assembly" NotFoundPage="typeof(NotFound)">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)">
            <NotAuthorized>
                <RedirectToLogin />
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
