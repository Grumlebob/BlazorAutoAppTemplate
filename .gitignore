# Build output
bin/
obj/
[Dd]ebug/
[Rr]elease/
artifacts/
*.binlog

# User and IDE state
.vs/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.user
*.suo
*.rsuser
*.DotSettings.user

# Local secrets and certificates
/.env
/.env.*
!/.env.example
/secrets.env
*.pfx
*.p12
*.key
*.crt
*.publishsettings
*.pubxml

# Node and frontend tooling
node_modules/
**/node_modules/
npm-debug.log*

# Test and coverage output
TestResults/
[Tt]est[Rr]esult*/
coverage*.json
coverage*.xml
coverage*.info
htmlcov/
.coverage

# Python helper caches
__pycache__/
**/__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local app runtime data
/data/storage/

# Local planning scratch space. Use docs/plans for retained plans.
/Plans/

# LocalCluster generated local inventory
/Deployment/LocalCluster/machines.yml
/Deployment/LocalCluster/inventory/prod/bootstrap-hosts.yml

# Cloud generated inventory, secrets, and OpenTofu local state
/Deployment/Cloud/inventory/prod/hosts.yml
/Deployment/Cloud/inventory/prod/vault.yml
/Deployment/Cloud/infra/opentofu/.terraform/
/Deployment/Cloud/infra/opentofu/*.tfstate
/Deployment/Cloud/infra/opentofu/*.tfstate.*
/Deployment/Cloud/infra/opentofu/*.tfplan
/Deployment/Cloud/infra/opentofu/*.plan
/Deployment/Cloud/infra/opentofu/*.tfvars
!/Deployment/Cloud/infra/opentofu/*.tfvars.example

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
agent.md
