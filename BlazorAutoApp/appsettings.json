{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "App": {
    "Name": "BlazorAutoApp"
  },
  "AllowedHosts": "*",
  "Books": {
    "SeedLocalDefaults": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=app;Username=postgres;Password=postgres;GSS Encryption Mode=Disable"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Redis": {
    "Configuration": "localhost:6379",
    "AllowMissing": false
  },
  "DataProtection": {
    "KeyStoragePath": "../data/storage/DataProtection-Keys"
  },
  "ForwardedHeaders": {
    "ForwardLimit": 1,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "Cache": {
    "Invalidation": {
      "Enabled": true,
      "PublishTimeoutSeconds": 2,
      "ApplyTimeoutSeconds": 5
    },
    "Books": {
      "ListTtlMinutes": 5,
      "ItemTtlMinutes": 10,
      "LocalListTtlSeconds": 5,
      "LocalItemTtlSeconds": 10,
      "DisableLocalCache": false
    }
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 600,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Api": {
      "PermitLimit": 60,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Authentication": {
      "PermitLimit": 120,
      "WindowSeconds": 300,
      "QueueLimit": 0
    }
  },
  "Authentication": {
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    }
  }
}
