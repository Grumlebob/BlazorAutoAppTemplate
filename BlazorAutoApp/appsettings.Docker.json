{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=app;Username=postgres;Password=postgres;GSS Encryption Mode=Disable"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://seq:5341" }
      }
    ]
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "Redis": {
    "Configuration": "redis:6379"
  },
  "Cache": {
    "Movies": {
      "ListTtlMinutes": 5,
      "ItemTtlMinutes": 10
    }
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 600,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Api": {
      "PermitLimit": 60,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Authentication": {
      "PermitLimit": 20,
      "WindowSeconds": 300,
      "QueueLimit": 0
    }
  }
}
