############################################
# Local Docker environment for BlazorAutoApp
#
# Copy this file to .env and keep .env uncommitted.
# Docker Compose reads .env through docker-compose.yml.
############################################

App__Url=https://localhost:7186

# PostgreSQL container and app database connection.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

Database__Host=postgres
Database__Port=5432
Database__Name=app
Database__Username=postgres
Database__Password=postgres

# Redis.
Redis__Configuration=redis:6379

# Optional Google auth. Leave blank unless testing Google login locally.
Authentication__Google__ClientId=
Authentication__Google__ClientSecret=

# Seq local logging container.
ACCEPT_EULA=Y
SEQ_FIRSTRUN_ADMINPASSWORD=ChangeMe123!
